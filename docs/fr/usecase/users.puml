@startuml usecase-users
!include ../_includes/style.iuml
!include ../_includes/usecase/actors.iuml

title Cas d'usage — qui fait quoi avec le sous-système IA

left to right direction

rectangle "Maestria — sous-système IA" {

  package "Onglet Inférence" as UC_UI {
    usecase "Ouvre un fichier modèle .gguf" as UC_OPEN
    usecase "Lance un modèle chat (UI navigateur)" as UC_RUN
    usecase "Caractériser / Re-caractériser" as UC_CH
    usecase "Voir le radar de compétence\n(R5 + arbre)" as UC_RADAR
    usecase "Caractérisation bulk\n(dossier)" as UC_BULK
  }

  package "Paramètres ▸ IA" as UC_SET {
    usecase "Choisir embedder .gguf\n(sélecteur de fichier)" as UC_PICK_EMB
    usecase "Activer sandbox tests-code\n(opt-in)" as UC_OPT_SBX
    usecase "Démarrer / arrêter serveur MCP" as UC_MCP
    usecase "Copier configuration MCP" as UC_COPY_CFG
    usecase "Override hardware" as UC_HW
  }

  package "Surface MCP" as UC_MCP_SURF {
    usecase "models.search / .get" as UC_SEARCH
    usecase "models.run / .stop" as UC_MRUN
    usecase "models.route\n(conseil seul)" as UC_ROUTE
    usecase "models.get_run_params\nmodels.list_runner_flags" as UC_INSPECT
    usecase "tags.add / .remove" as UC_TAGS
    usecase "description.set / .get" as UC_DESC
    usecase "hf.fetch (métadonnées)" as UC_FETCH
    usecase "hardware.detect /\n.autotune" as UC_HW_TOOL
  }
}

A_USER --> UC_OPEN
A_USER --> UC_RUN
A_USER --> UC_CH
A_USER --> UC_RADAR
A_USER --> UC_BULK
A_USER --> UC_PICK_EMB
A_USER --> UC_OPT_SBX
A_USER --> UC_MCP
A_USER --> UC_COPY_CFG
A_USER --> UC_HW

A_MCP_CLI --> UC_SEARCH
A_MCP_CLI --> UC_MRUN
A_MCP_CLI --> UC_ROUTE
A_MCP_CLI --> UC_INSPECT
A_MCP_CLI --> UC_TAGS
A_MCP_CLI --> UC_DESC
A_MCP_CLI --> UC_FETCH
A_MCP_CLI --> UC_HW_TOOL

UC_FETCH ..> A_HF : (egress)
UC_PICK_EMB ..> A_EXT_EMB : (alternative\nà managed)
UC_ROUTE ..> UC_MRUN : <<extends>>\nsuite
UC_INSPECT ..> UC_MRUN : <<precedes>>

note bottom of UC_OPT_SBX
  Opt-in OFF par défaut. Débloque
  les 9 items de tests-code dans
  l'escalier ; sinon ils restent
  UNMEASURED (prior D12).
end note

note bottom of UC_ROUTE
  Conseil seul — NE lance RIEN.
  L'appelant fait suivre par models.run.
end note

@enduml
