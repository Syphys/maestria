@startuml sandbox-execution
!include ../_includes/style.iuml

title Sandbox — cycle de vie isolation par OS (slice 2d)

participant "staircase.\nevaluateItem" as STAIR
participant "characterizeRunner\n(construit le seam)" as RUN
participant "getSandbox({enabled})" as DISP
participant "PosixSandbox\n/ WindowsSandbox\n/ UnsafeSandbox" as PROV
participant "spawn (child_process)" as SPAWN
participant "kernel\n(rlimits / Job Object)" as KERNEL
participant "child python" as PY

STAIR -> RUN : item est sandbox-request\n(a besoin du seam runSandbox)
RUN -> DISP : params.enableSandbox ?
DISP --> RUN : instance provider

alt UnsafeSandbox (opt-in OFF, défaut)
  RUN -> PROV : runPythonTests(code, tests)
  PROV --> RUN : throw SandboxUnavailable
  RUN --> STAIR : item ⇒ UNMEASURED (prior D12)
else PosixSandbox (linux/darwin, opt-in ON)
  RUN -> PROV : runPythonTests(code, tests)
  PROV -> PROV : sonde findPython()
  alt sonde échoue
    PROV --> RUN : throw SandboxUnavailable
    RUN --> STAIR : UNMEASURED
  else sonde OK
    PROV -> PROV : mkdtemp + écrit script\n  (préambule + code + tests)
    PROV -> SPAWN : python -I -S -B script.py\n  detached:true (pgrp propre)\n  env minimal
    SPAWN -> PY : exec
    PY -> KERNEL : setrlimit NPROC=cur,\n  AS=512M, CPU=10s, FSIZE=0
    KERNEL --> PY : arme les limites
    PY -> PY : exécute le code du modèle + asserts
    alt asserts pass, exit 0
      PY --> SPAWN : exit 0
      SPAWN --> PROV : close(0)
      PROV --> RUN : {pass: true}
    else assert fail / exception
      PY --> SPAWN : exit 1
      PROV --> RUN : {pass: false, reason: exit-nonzero}
    else timeout (parent enforce)
      PROV -> PROV : kill -pgid SIGKILL
      PROV --> RUN : {pass: false, reason: timeout}
    else overflow d'output
      PROV -> PROV : kill -pgid SIGKILL
      PROV --> RUN : {pass: false, reason: output-overflow}
    end
    PROV -> PROV : rmtree workdir (finally)
  end
else WindowsSandbox (win32, opt-in ON)
  RUN -> PROV : runPythonTests(code, tests)
  PROV -> SPAWN : powershell.exe -File win-job.ps1
  SPAWN -> KERNEL : CreateJobObject +\n  SetInformationJobObject\n  (ActiveProcess=1,\n   MemoryLimit=512MiB,\n   KILL_ON_JOB_CLOSE)
  KERNEL --> SPAWN : handle de job
  SPAWN -> PY : Process.Start(python.exe)
  SPAWN -> KERNEL : AssignProcessToJobObject
  PY -> PY : exécute script
  alt WaitForExit retourne à temps
    PY --> SPAWN : code d'exit
    SPAWN --> PROV : code d'exit + marker-line\n  stdout/stderr
  else timeout
    SPAWN -> KERNEL : TerminateJobObject (1)
    SPAWN --> PROV : exit 124
  end
  PROV --> RUN : {pass, reason}
end

@enduml
