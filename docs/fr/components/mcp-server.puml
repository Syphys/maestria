@startuml mcp-server
!include ../_includes/style.iuml
!include ../_includes/actors.iuml

title Serveur MCP — surface parité UI complète + auth à deux tokens (2026-05-24)

package "src/main/modelhub/mcp/" as MCP_PKG {
  component "index.ts\n• imports side-effect\n  de chaque module tool\n  (auto-enregistrement)\n• re-exporte start/stop\n  + tokens user/admin" as INDEX
  component "server.ts\n• HTTP+SSE sur\n  127.0.0.1:41541\n• Express + middleware\n  Bearer (deux niveaux)\n• callerLabelFor(req)\n  depuis User-Agent\n• stash ctx.isAdmin\n  sur le transport" as SERVER
  component "registry.ts\n• Map<name,\n  ToolDefinition>\n• flag requiresAdmin\n• isAdmin dans ctx\n• ListTools trié par\n  nom\n• court-circuit 403\n  sur admin gate" as REG
  component "token.ts\n• Bearer user\n  (création lazy)\n• Bearer admin\n  (opt-in,\n   regénérer,\n   révoquer)\n• toggle autoStart" as TOKEN
  component "logger.ts\n• appendCallLog()\n• rotatif\n  ~/.tagspaces/mcp.log\n• caller / tool /\n  durée / ok|err\n  / admin-rejeté" as LOGGER

  package "tools/ (auto-enregistrement à l'import) — ~40 au total" as TOOLS {
    component "models.ts (7)\n• search\n• get  (KV brut opt-in)\n• list_running\n• run (admin? ⇒ UAC)\n• stop\n• get_run_params\n• list_runner_flags" as T_MODELS
    component "route.ts (1)\n• models.route\n  · embedder-gated\n  · projection vectorielle\n  · fallback R5" as T_ROUTE
    component "characterize.ts (6)\n• start / status\n• all_start (long)\n• all_cancel\n• load_signature\n• get_questions_dir" as T_CHAR
    component "logs.ts (4)\n• models.get_server_log\n• models.get_error_log\n• models.list_archives\n• runners.get_log" as T_LOGS
    component "meta.ts (4) ⚠\n• meta.patch (ouvert)\n• meta.enrich (ouvert)\n• enrich.folder_start ⚠\n• meta.clear_folder ⚠" as T_META
    component "discovery.ts (2)\n• sum_shard_bytes\n• list_hosting_folders" as T_DISC
    component "runners.ts (9) ⚠\n• list / dismiss /\n  open_chat /\n  build_command /\n  fit_probe (ouvert)\n• save / remove /\n  detect / reprobe ⚠" as T_RUNN
    component "configs.ts (5) ⚠\n• hardware.detect_raw\n• hardware.get_override\n• hardware.set_override ⚠\n• routing.get_config\n• routing.set_config ⚠" as T_CFG
    component "tags.ts (2)\n• tags.add\n• tags.remove" as T_TAGS
    component "description.ts (2)\n• description.get\n• description.set" as T_DESC
    component "hardware.ts (2)\n• hardware.detect\n• hardware.autotune" as T_HW
  }
}

component "launch.ts\n+ launchProcessElevated\n(UAC / pkexec)" as LAUNCH
component "routeDecision.ts\n+ routeByVectors.ts\n+ embedderLifecycle" as ROUTE_CORE
component "characterizeRunner.ts\n+ characterizeAll.ts" as CHAR_CORE
component "modelLogStore.ts\n+ runners/launch.getEntryLog" as LOGS_CORE
component "enrichFolder + clearFolder\n+ sidecar.patchModelMeta" as META_CORE
component "runners/registry +\nfitProbe + openChat" as RUNN_CORE
component "hardwareOverride +\nroutingConfig" as CFG_CORE
component "Paramètres ▸ IA ▸ MCP\n(hook useMcp.ts,\nrenderer — générateur\nde token admin)" as UI_SETTINGS_R

MCP_CLIENT --> SERVER : GET /sse\nPOST /messages?sessionId=…\nAuthorization: Bearer <user|admin>
SERVER --> TOKEN : vérifie Bearer\n(les deux tokens lus à\n chaque requête — révoke\n prend effet immédiat)
SERVER --> REG : dispatch CallTool\n(ctx.isAdmin selon le tier de token)
SERVER --> LOGGER : appendCallLog(caller,\n  tool, args, durée, ok|err)

REG --> T_MODELS
REG --> T_ROUTE
REG --> T_CHAR
REG --> T_LOGS
REG --> T_META : (sous-ensemble admin-gated)
REG --> T_DISC
REG --> T_RUNN : (sous-ensemble admin-gated)
REG --> T_CFG  : (sous-ensemble admin-gated)
REG --> T_TAGS
REG --> T_DESC
REG --> T_HW

INDEX ..> T_MODELS : import (register)
INDEX ..> T_ROUTE  : import (register)
INDEX ..> T_CHAR   : import (register)
INDEX ..> T_LOGS   : import (register)
INDEX ..> T_META   : import (register)
INDEX ..> T_DISC   : import (register)
INDEX ..> T_RUNN   : import (register)
INDEX ..> T_CFG    : import (register)
INDEX ..> T_TAGS   : import (register)
INDEX ..> T_DESC   : import (register)
INDEX ..> T_HW     : import (register)

T_MODELS --> LAUNCH : list / spawn (launchedBy =\n  ctx.callerLabel) / stop\n  / launchProcessElevated\n  quand admin:true
T_MODELS --> SIDECARS : resolveCanonicalShardPath\n+ loadModelMeta\n+ aperçu autotune
T_ROUTE --> ROUTE_CORE : decideRoute\n(probeFreeMemory + gate embedder)
T_CHAR --> CHAR_CORE : runCharacterization,\ncharacterizeAll,\nloadSignature
T_LOGS --> LOGS_CORE : readServerLog / readErrorLog /\nlistServerLogArchives /\ngetEntryLog
T_META --> META_CORE : enrichLocal /\nenrichFolder /\nclearFolder /\npatchModelMeta
T_DISC --> SIDECARS : sumShardBytes /\nlistModelHostingFolders
T_RUNN --> RUNN_CORE : listRunners / saveRunner /\nremoveRunner / reprobe /\nfitProbe / openChatFor /\nbuildCommand
T_CFG --> CFG_CORE : getOverride / setOverride /\ngetRoutingConfig / setRoutingConfig
T_TAGS --> SIDECARS : patchSidecar({tags})
T_DESC --> SIDECARS : patchSidecar({description})
T_HW ..> "Profileur\nhardware" : detect + aperçu autotune

UI_SETTINGS_R --> INDEX : start / stop /\nregénère token user /\nget|create|regénère|\nrévoque token admin\n(IPC, statut polled 5 s)

note bottom of REG
  Authentification à deux niveaux.
  Chaque ToolDefinition opt-in
  `requiresAdmin: true`. Token par
  défaut (user) : chaque tool SAUF
  ceux-là. Token admin : chaque tool
  ET la branche `admin: true` de
  models.run (élévation niveau OS).
  Le check serveur retourne une
  réponse MCP `isError: true`,
  PAS HTTP 401 — la session reste
  vivante, seul l'appel spécifique
  est interdit.
end note

note bottom of SERVER
  callerLabel dérivé du header
  User-Agent de la requête
  (trimé au premier espace/`(`) —
  fallback vers le hash court de
  sessionId. Surface comme
  `launchedBy` sur chaque modèle
  que l'appelant spawne, donc le
  Superviseur les groupe par
  provenance.
  ⚠ Les tokens admin déverrouillent
  les ops destructives ET
  l'élévation de privilège OS-level
  pour les processus llama-server
  spawnés.
end note

@enduml
