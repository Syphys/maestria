@startuml routing
!include ../_includes/style.iuml
!include ../_includes/legend.iuml

title Routing — pipeline `models.route` (slice 5b + 7)

[*] --> ENTRY
state "tool MCP models.route" as ENTRY
state "charge routing config\n+ effectiveRoutingParams()" as CFG
state "liste modèles candidats\n(seulement signatures complètes — D9)" as CANDS
state "Sonde mémoire libre\n(VRAM/RAM, ensemble résident)" as PROBE
state "Embedder configuré ?" as Q_EMBED
state "Gate de fiabilité ≥ θ" as Q_GATE

state "Chemin VECTEUR (routedBy:'vector')" as VEC {
  state "EmbedClient → vecteur query\n(slice 7e ensureEmbedderReady)" as EMBED_Q
  state "Projette sur 32 ancres feuilles\n(`probe-anchors.json`)" as PROJECT
  state "Blend α·v_det + β·max(0, tc)\n(α=0.7, β=0.3)" as BLEND
}

state "Chemin R5 (routedBy:'r5')" as R5 {
  state "classifyQuery()\npoids d'axes déterministes" as CLASSIFY
  state "Map sur priors de branche" as MAP_BRANCH
}

state "Score chaque candidat\nC_m = Σ q[i]·v_m[i]\n+ w_fit·fit + w_hot·hot" as SCORE
state "rank + sélection meilleur\nfiltre vers éligibles (D9)" as RANK
state "retourne {routedBy, gateReason,\n best, ranked, resources, …}" as OUT

ENTRY --> CFG
CFG --> CANDS
CANDS --> PROBE
PROBE --> Q_EMBED

Q_EMBED --> Q_GATE : configuré\n(managed ou external)
Q_EMBED --> R5 : absent\n(fallback R5)
Q_GATE --> VEC : embeddingReliability\n≥ seuil
Q_GATE --> R5 : sous le seuil\n(gateReason explique)

VEC --> EMBED_Q
EMBED_Q --> PROJECT
PROJECT --> BLEND
BLEND --> SCORE

R5 --> CLASSIFY
CLASSIFY --> MAP_BRANCH
MAP_BRANCH --> SCORE

SCORE --> RANK
RANK --> OUT

note right of BLEND
  topic_coverage_per_leaf
  (slice 7c) est une **évidence
  supplémentaire**, ne remplace
  jamais la compétence déterministe.
  Voir DECISIONS.md DCC.
end note

note right of Q_GATE
  Échec d'embed de query ou de
  lecture de fiabilité ⇒ fallback
  silencieux vers R5. Le routing
  n'est **jamais bloquant**.
end note

@enduml
