' Partial — participants récurrents pour les diagrammes de séquence.
' Les composeurs incluent ceci puis ajoutent leurs interactions
' spécifiques. Les alias sont stables ; si un participant est renommé,
' chaque séquence se met à jour d'un coup.

participant "Utilisateur\n(onglet Inférence)" as P_USER
participant "Client MCP\n(Claude Code,\nCursor, deer-flow)" as P_MCP_CLI
participant "Serveur MCP\n+ registry" as P_MCP_SRV
participant "characterizeRunner" as P_CH_RUNNER
participant "characterizeTree" as P_CH_TREE
participant "staircase\n+ scorers" as P_CH_STAIR
participant "freegen" as P_CH_FG
participant "embedderLifecycle" as P_EMB_LC
participant "EmbedClient" as P_EMB_CLI
participant "ChatClient\n(routing/chat.ts)" as P_CHAT_CLI
participant "routeDecision\n+ routeByVectors" as P_ROUTE
participant "classifyQuery (R5)" as P_R5
participant "Provider sandbox\n(dispatch getSandbox)" as P_SBX
participant "launch.ts\n(runner registry)" as P_LAUNCH
participant "signatureStore" as P_SIG
participant "llama-server\n(chat)" as P_LLAMA_CHAT
participant "llama-server\n--embedding" as P_LLAMA_EMB
participant "child python\n(sandboxé)" as P_PY
