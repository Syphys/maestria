' Partial — composants du pipeline de caractérisation.

package "src/main/modelhub/routing/ (caractérisation)" <<Folder>> as PKG_CHARACT {
  component "characterizeRunner.ts\n(orchestrateur haut niveau)" as CMP_CH_RUNNER
  component "characterize.ts\n(passe R5)" as CMP_CH_R5
  component "characterizeTree.ts\n(passe arbre,\nR5-gated)" as CMP_CH_TREE
  component "staircase.ts\n(escalier style CAT,\nBeta-Laplace)" as CMP_CH_STAIR
  component "freegen.ts\n(sonde slice 7c)" as CMP_CH_FG
  component "signatureStore.ts\n(I/O .ts/<fichier>.json)" as CMP_CH_STORE
  component "chat.ts\n(ChatClient,\npas de timeout)" as CMP_CH_CHAT

  package "scorers/" as PKG_SCORERS {
    component "checkSpec.ts\n(dispatch runCheck)" as CMP_SC_CORE
    component "10 scorers\ndéterministes" as CMP_SC_DET
    component "4 scorers d'axe" as CMP_SC_AXIS
    component "scorer informatique" as CMP_SC_INFO
    component "scorers\nsandbox-pending (slice 2d)" as CMP_SC_PEND
  }
}
