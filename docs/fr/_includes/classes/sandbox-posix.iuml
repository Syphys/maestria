' Partial — PosixSandbox + seam de test Spawner.
' Source : src/main/modelhub/routing/sandbox/posix.ts.

package "src/main/modelhub/routing/sandbox/posix.ts" <<Frame>> as PKG_SBX_POSIX {

  class PosixSandbox {
    + kind = 'posix'
    - spawner : Spawner   (seam de test)
    - pythonBin? : string   (sondé en lazy)
    --
    + runPythonTests(...)
    - findPython()
    - probeBinary(bin)
    - spawnIsolated(...)
    --
    Frontières (kernel) :
    • RLIMIT_NPROC = cur   (T2/T7)
    • RLIMIT_AS / DATA = 512 MiB   (T6)
    • RLIMIT_CPU = 10 s   (T1)
    • RLIMIT_FSIZE = 0   (T4)
    Plus : pgrp détaché + kill(-pgid),
    env vide, workdir jetable,
    python -I -S -B.
  }

  class "type Spawner" as Spawner <<type>> {
    (cmd, args, options) => ChildProcess
    Ré-exporté par windows.ts pour symétrie
  }
}
