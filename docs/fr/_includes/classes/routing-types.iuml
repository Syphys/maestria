' Partial — définitions de classes pour les types routing/signature.
' Source : src/shared/RoutingTypes.ts (fichier unique).
' Inclus par : classes/signature.puml (et tout futur composeur qui
' a besoin de référencer ces shapes).
'
' Conventions :
'   - Pas de `@startuml` / `@enduml` ici (c'est un include seul).
'   - Les IDs de classes sont stables — les composeurs les référencent par alias.
'   - Le wrapper `<<Frame>>` donne l'indice de groupement par fichier.

package "src/shared/RoutingTypes.ts" <<Frame>> as PKG_ROUTING_TYPES {

  class Signature {
    + modelHash : string
    + suite_version : string
    + characterized_at : ISO 8601
    + characterization_state : 'complete' | 'incomplete' | 'quarantined'
    + structural : StructuralSignature
    + behavioral : BehavioralSignature
    + qcm_reliability : QcmReliability
    + embedder_id : string   <i>(slice 7c)</i>
  }

  class StructuralSignature {
    + est_footprint_bytes : number  <i>(D9 fit-scoring)</i>
    + tensor_count : number
    + arch : string
    + quant : string
    + ctx_max : number
    + …
  }

  class BehavioralSignature {
    + diagnostic_run : Record<promptId, DiagnosticRunEntry>
    + scores_per_axis : Partial<Record<DiagnosticAxis, number>>
    + n_per_axis? : Partial<Record<DiagnosticAxis, number>>
    + overall? : number
    --
    <b>Champs tree-routing (slice 4c+)</b>
    + scores_per_leaf? : Record<leafId, number>  <i>(0..1 — voir scheme)</i>
    + branch_scores? : Partial<Record<CompetenceBranch, number>>
    + n_per_leaf? : Record<leafId, number>
    + passes_per_leaf? : Record<leafId, number>  <i>(beta-laplace seulement)</i>
    + scoring_scheme? : 'beta-laplace-v1' | 'breaking-rung-v0'
    --
    <b>Sonde Free-gen (slice 7c)</b>
    + topic_coverage_per_leaf? : Record<leafId, number>  <i>(cosinus)</i>
    + topic_coverage_per_branch? : Record<CompetenceBranch, number>
    + freegen_words? : number
    + freegen_excerpt? : string
  }

  class DiagnosticRunEntry {
    + id : string
    + axes : DiagnosticAxis[]
    + pass : boolean
    + score? : number
    + response : string
    + detail? : string
    + error? : string
  }

  class QcmReliability {
    + format_adherence : number  <i>(0..1)</i>
    + consistency : number
    + overall : number  <i>(affichage seul — N'ENTRE JAMAIS dans le routing)</i>
    + n : number
  }
}
