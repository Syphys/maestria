@startuml system-overview
!include _includes/style.iuml
!include _includes/actors.iuml

title Maestria — vue d'ensemble du sous-système IA

package "Maestria (app Electron)" as MAESTRIA {
  package "Renderer (React)" {
    component "ModelHubPanel\n+ onglet Inférence" as UI_PANEL
    component "CompetenceSection\n(radar R5 +\nradar arbre)" as UI_RADAR
    component "Paramètres ▸ IA\n▸ Routing" as UI_SETTINGS
  }
  package "Processus main" {
    component "Serveur MCP\n(127.0.0.1:41541,\nauth Bearer)" as MCP_SERVER
    component "Registry des tools\n(models.*,\ntags.*, hf.*,\nhardware.*, route)" as REGISTRY
    component "Routing\n(routeByVectors\n+ fallback R5)" as ROUTING
    component "Runner de\ncaractérisation\n+ arbre + escalier" as CHARACT
    component "Dispatch sandbox\n(rlimits POSIX /\nJob Object Win /\nUnsafe)" as SANDBOX
    component "Cycle de vie\nembedder\n(slice 7e)" as EMBED_LC
    component "Registry des runners\n+ launch.ts\n(llama-server)" as RUNNERS
  }
}

USER --> UI_PANEL : ouvre un .gguf
USER --> UI_SETTINGS : configure embedder /\nopt-in sandbox
UI_PANEL --> CHARACT : caractériser
UI_PANEL --> RUNNERS : Run (chat)
UI_RADAR --> CHARACT : re-caractériser

MCP_CLIENT --> MCP_SERVER : HTTP+SSE\n(Bearer token)
MCP_SERVER --> REGISTRY
REGISTRY --> ROUTING : models.route
REGISTRY --> CHARACT : (via tools)
REGISTRY --> RUNNERS : models.run / .stop

CHARACT --> RUNNERS : assure URL chat\nvivante
CHARACT --> EMBED_LC : sonde optionnelle\n(slice 7c)
CHARACT --> SANDBOX : tests code\n(slice 2d)
ROUTING --> EMBED_LC : projection query\n(slice 7e)

RUNNERS --> LLAMA_CHAT : spawn
EMBED_LC --> LLAMA_EMBED : spawn\n--embedding
SANDBOX --> PYTHON_SANDBOX : spawn\nisolé

CHARACT --> SIDECARS : écrit signature
ROUTING --> SIDECARS : lit signature
REGISTRY --> HF : hf.fetch

note bottom of MAESTRIA
  100% local, offline, pas de télémétrie.
  llama-server + python (sandbox)
  sont des processus enfants ; rien
  ne se bind hors de 127.0.0.1.
end note

@enduml
