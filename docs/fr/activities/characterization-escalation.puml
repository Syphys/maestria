@startuml activity-characterization-escalation
!include ../_includes/style.iuml

title Activité — escalade de caractérisation\nR5 → arbre → freegen avec deepening R5-gated

' Slice 6a Dββ — seules les branches R5-maximales sont approfondies sur l'arbre.
' Ce diagramme d'activité montre les points de décision + l'isolement
' d'échec entre les passes.

start
:L'utilisateur clique "Caractériser"\nOU requête MCP;

partition "Filtre non-chat pré-lancement (2026-05-24)" {
  :Lit le header GGUF UNE FOIS
  (arch + general.name + pooling);
  if (arch ∈ NON_GENERATIVE_ARCH ?
    whisper/clip/bert/t5/...
    + qwen3tts/outetts/parlertts/
    kokoro/mossttts/snactts) then (oui)
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (general.name matche
    /[_\W](tokenizer|codec|vocoder|
    vq|cfm|tts)[_\W]/i ?) then (oui)
    note right
      Cosyvoice3 = nom
      "Llamacpp_Tokenizer"
      → catché ici, ne boote
      jamais llama-server.
    end note
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (pooling_type ≥ 1 ?
    Qwen3-Embedding-N etc.) then (oui)
    :throw UnsupportedModelError
    ("modèle d'embedding");
    :state = 'failed' (quarantined);
    stop
  endif
}

:characterizeRunner assure que\nle processus chat est vivant;
:archiveServerLog
(rotate le .log précédent →
 .ts/<fichier>.<ISO>.log,
 session fraîche démarre propre);

partition "Passe R5 (grossière, toujours)" {
  :Itère sur les prompts v1-30.json;
  repeat
    :ask.complete(prompt)
    (pas de timeout client — attend
     aussi longtemps que le modèle a besoin);
    :émet événement prompt_done
    avec DiagnosticRunEntry COMPLET
    (onglet Interactions live,
     2026-05-24);
    :Lance le scorer enregistré;
    :Met à jour scores_per_axis;
    if (Tier 3 — quarantaine adaptative ?
      réponse uniquement tokens `<|stop_…|>`
      OU 5 vides consécutifs) then (oui)
      note right
        Attrape les GGUFs TTS / audio-codec
        que les filtres arch+nom ont raté
        (ex. une variante Cosyvoice
        avec un general.name innocent).
      end note
      :throw 'non-chat model';
      :state = 'failed' (quarantined);
      stop
    endif
  repeat while (encore des prompts ?) is (oui)
  -> R5 fini;
  :Persiste behavioral\n+ characterization_state = 'incomplete';
}

if (characterizeTreeFn disponible ?) then (non)
  :L'état reste 'incomplete';
  stop
endif

partition "Passe arbre (R5-gated, Dββ)" {
  :Lit scores_per_axis;
  :branchGateFromAxes()\nmap R5 → 9 branches;
  fork
    :Pour chaque branche où\n  R5 mapped score ≥ θ_open;
    :characterizeBranch\n(Phase A : sonde niveau 1,\npuis monte jusqu'au 1er fail);
    if (passes_per_leaf > 0 ?) then (oui)
      :Posterior Beta-Laplace\n(1+passes)/(2+asked);
    else (non)
      :Marque UNMEASURED\n→ prior de branche D12;
    endif
  fork again
    :Pour chaque branche où R5 < θ_open;
    :Skip (cost-bounded);
    :Les feuilles restent au\nQCM-prior (qcmDiscount · pass);
  end fork
  :Merge dans BehavioralSignature\n(scores_per_leaf, branch_scores,\npasses_per_leaf, n_per_leaf);
  if (passe arbre catastrophiquement échouée ?) then (oui)
    :Log + GARDE résultat R5;
    :state = 'incomplete';
    stop
  endif
}

partition "Free-gen PHASE 1 — texte seul (split 2026-05-22)" {
  if (opts.freegen !== false ?) then (non)
    :Skip silencieusement;
  else (oui)
    if (generateFreeGenText) then (réussit)
      :ask.complete(FREEGEN_PROMPT)\n~600-800 mots\nPAS besoin d'embedder;
      :Strip <think>…</think> (D11);
      :Persiste freegen_text + freegen_words;
    else (throw)
      :Log + skip (DCC §5\nisolation : arbre gardé);
    endif
  endif
}

:state = 'complete';
:Persiste signature (passe test finie);
:Stop test server\n(libère RAM modèle);

partition "Free-gen PHASE 2 — projection (par modèle, single-pass)" {
  if (opts.skipProjection OU\nembedder injoignable ?) then (oui)
    :Diffère projection\n(texte déjà sauvé);
  else (non)
    :embedderCli.embedViaLlamaCli\n(spawn llama-embedding.exe,\nbatch texte + 17 ancres,\nJSON out, processus exit);
    :projectFreeGenText\n(projection cosinus);
    :Patch signature :\ntopic_coverage_per_leaf,\ntopic_coverage_per_branch;
  endif
}

:Rafraîchit radar UI (R5 + arbre + projection);
stop

note right
  Trois passes indépendantes,
  chacune isolée en cas d'échec
  de la suivante. La garantie la
  plus forte est : un R5 qui marche
  atterrit toujours, même si l'arbre
  + freegen meurent.
  Le split free-gen (2026-05-22) permet
  à la phase 1 de toujours tourner (pas
  de dépendance embedder) ; la phase 2
  peut être différée ou faite plus tard
  sur le texte stocké sans relancer le
  modèle de test.
end note

@enduml
