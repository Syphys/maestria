@startuml c4-context
!include ../_includes/style.iuml

' Bonus — diagramme C4 Context. Altitude plus haute que notre vue composant :
' Maestria comme boîte noire + chaque système externe qu'elle touche.
'
' (Hand-rolled — on évite la lib officielle C4-PlantUML pour ne pas
' introduire un include réseau.)

skinparam rectangle {
  StereotypeFontSize 10
}

title Maestria — Contexte C4

actor "Utilisateur humain" as USER
rectangle "**Maestria**\n<size:10>navigateur et gestionnaire de modèles IA locaux</size>\n<size:10>AGPL-3.0, offline, pas de télémétrie</size>" as SYS #FFFDF6

rectangle "Clients MCP externes" <<system>> as MCP {
  rectangle "Claude Code" as MCP_CC
  rectangle "Cursor" as MCP_CUR
  rectangle "deer-flow" as MCP_DF
  rectangle "scripts / curl" as MCP_SH
}
rectangle "llama.cpp\n(binaire `llama-server`)" <<system>> as LLAMA
rectangle "Hugging Face\n(API métadonnées)" <<system>> as HF
rectangle "Système de fichiers utilisateur\n(D:\\models, sidecars .ts/,\ndonnées app ~/.tagspaces/)" <<storage>> as FS

USER --> SYS : Ouvre .gguf, caractérise,\ntague, configure routing,\nchat ouvert-dans-navigateur
SYS --> LLAMA : Spawn processus enfant,\nmonitore PID + URL
SYS --> FS : Lit modèles,\nécrit sidecars / logs
SYS --> HF : hf.fetch métadonnées\n(action utilisateur opt-in)
MCP --> SYS : HTTP+SSE sur 127.0.0.1:41541\nauth Bearer-token,\ntools/call

note bottom of SYS
  Rien ne quitte 127.0.0.1
  sauf hf.fetch (et seulement
  sur action utilisateur explicite).
  Pas de télémétrie, pas d'auto-update.
end note

note right of LLAMA
  Binaire externe, non bundlé.
  L'utilisateur l'installe lui-même.
  Maestria le détecte + autotune
  selon le hardware.
end note

@enduml
