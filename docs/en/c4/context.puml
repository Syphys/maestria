@startuml c4-context
!include ../_includes/style.iuml

' Bonus — C4 Context diagram. Higher altitude than our component view:
' Maestria as a black box + every external system it touches.
'
' (Hand-rolled — we avoid the official C4-PlantUML library so we
' don't introduce a network include.)

skinparam rectangle {
  StereotypeFontSize 10
}

title STR_C4CTX_TITLE

actor "STR_C4CTX_USER" as USER
rectangle "STR_C4CTX_SYS_LABEL" as SYS #FFFDF6

rectangle "STR_C4CTX_MCP_LABEL" <<system>> as MCP {
  rectangle "Claude Code" as MCP_CC
  rectangle "Cursor" as MCP_CUR
  rectangle "deer-flow" as MCP_DF
  rectangle "STR_C4CTX_MCP_SH" as MCP_SH
}
rectangle "STR_C4CTX_LLAMA_LABEL" <<system>> as LLAMA
rectangle "STR_C4CTX_FS_LABEL" <<storage>> as FS

USER --> SYS : STR_C4CTX_REL_USER_SYS
SYS --> LLAMA : STR_C4CTX_REL_SYS_LLAMA
SYS --> FS : STR_C4CTX_REL_SYS_FS
MCP --> SYS : STR_C4CTX_REL_MCP_SYS

note bottom of SYS
  STR_C4CTX_NOTE_SYS_L1
  STR_C4CTX_NOTE_SYS_L2
end note

note right of LLAMA
  STR_C4CTX_NOTE_LLAMA_L1
  STR_C4CTX_NOTE_LLAMA_L2
  STR_C4CTX_NOTE_LLAMA_L3
  STR_C4CTX_NOTE_LLAMA_L4
end note

@enduml
