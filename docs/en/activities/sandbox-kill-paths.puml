@startuml activity-sandbox-kill-paths
!include ../_includes/style.iuml

title STR_SKILL_TITLE

' Disambiguates the FOUR reasons runPythonTests() returns {pass:false}
' vs the SIX reasons it throws SandboxUnavailable. The former is a
' real characterization signal (the model's code didn't work); the
' latter is "we can't trust this measurement" ⇒ UNMEASURED.

start
:STR_SKILL_STEP_BUILD_SEAM;
:STR_SKILL_STEP_EVAL_CALL;

if (Provider) then (UnsafeSandbox)
  :STR_SKILL_STEP_THROW_OPTIN;
  -> unavailable;
elseif (PosixSandbox / WindowsSandbox)
  if (STR_SKILL_IF_FIND_PY) then (STR_SKILL_NO)
    :STR_SKILL_STEP_THROW_NO_PY;
    -> unavailable;
  endif
  if (STR_SKILL_IF_MKDTEMP) then (STR_SKILL_NO)
    :throw SandboxUnavailable\n("mkdtemp" / "write");
    -> unavailable;
  endif
  if (STR_SKILL_IF_SETRLIMIT) then (STR_SKILL_NO)
    note right : STR_SKILL_NOTE_RLIMIT
  endif
  :STR_SKILL_STEP_SPAWN;
  if (STR_SKILL_IF_SPAWN_ERR) then (STR_SKILL_YES)
    :STR_SKILL_STEP_THROW_SPAWN;
    -> unavailable;
  endif
  fork
    :STR_SKILL_STEP_WAIT_CLOSE;
  fork again
    :STR_SKILL_STEP_TIMER;
    if (STR_SKILL_IF_ELAPSED) then (STR_SKILL_YES)
      :kill(-pgid, SIGKILL);
      :reason = 'timeout';
    endif
  fork again
    :STR_SKILL_STEP_OUT_WATCHER;
    if (STR_SKILL_IF_THRESHOLD) then (STR_SKILL_YES)
      :kill(-pgid, SIGKILL);
      :reason = 'output-overflow';
    endif
  end fork
  if (STR_SKILL_IF_EXIT0) then (STR_SKILL_YES)
    :STR_SKILL_STEP_RET_PASS;
  elseif (STR_SKILL_IF_KILLED_BY_US) then (STR_SKILL_YES)
    :STR_SKILL_STEP_RET_FAIL_REASON;
  else (STR_SKILL_OTHER_NONZERO)
    :STR_SKILL_STEP_RET_FAIL_EXITNZ;
  endif
  -> measured;
endif

label measured
:STR_SKILL_STEP_ITEM_PASSFAIL;
stop

label unavailable
:STR_SKILL_STEP_CATCH;
:STR_SKILL_STEP_ITEM_UNMEAS;
:STR_SKILL_STEP_LEAF_PRIOR;
stop

floating note left
  STR_SKILL_NOTE_MEAS_L1
  STR_SKILL_NOTE_MEAS_L2
  STR_SKILL_NOTE_MEAS_L3
  STR_SKILL_NOTE_MEAS_L4
  STR_SKILL_NOTE_MEAS_L5
end note

floating note left
  STR_SKILL_NOTE_UNAV_L1
  STR_SKILL_NOTE_UNAV_L2
  STR_SKILL_NOTE_UNAV_L3
  STR_SKILL_NOTE_UNAV_L4
  STR_SKILL_NOTE_UNAV_L5
end note

@enduml
