@startuml activity-routing-decision
!include ../_includes/style.iuml

title STR_RTDEC_TITLE

' Activity diagram for the routing decision logic. Distinct from the
' sequence (which shows WHO calls WHO) — here we show the BRANCHING
' (if embedder, if reliable, if α/β blend, …).

start

:STR_RTDEC_STEP_LOAD_CFG;
:STR_RTDEC_STEP_LIST_CANDS;
:STR_RTDEC_STEP_PROBE;

if (STR_RTDEC_IF_EMB_CONFIG) then (STR_RTDEC_NO)
  :STR_RTDEC_STEP_USE_R5;
  note right
    STR_RTDEC_NOTE_R5_L1
    STR_RTDEC_NOTE_R5_L2
    STR_RTDEC_NOTE_R5_L3
  end note
  -> r5_path;
else (STR_RTDEC_YES)
  :STR_RTDEC_STEP_ENSURE_READY;
  if (STR_RTDEC_IF_EMB_LIVE) then (STR_RTDEC_NO)
    :STR_RTDEC_STEP_FALLBACK_DOWN;
    -> r5_path;
  else (STR_RTDEC_YES)
    :STR_RTDEC_STEP_MEASURE_REL;
    if (STR_RTDEC_IF_ALL_LANGS) then (STR_RTDEC_NO)
      :STR_RTDEC_STEP_FALLBACK_THR;
      -> r5_path;
    else (STR_RTDEC_YES)
      :STR_RTDEC_STEP_EMBED_QUERY;
      :STR_RTDEC_STEP_PROJECT;
      if (STR_RTDEC_IF_PERLEAF_CONF) then (STR_RTDEC_YES)
        :STR_RTDEC_STEP_DESC_LEAF;
      else (STR_RTDEC_NO)
        :STR_RTDEC_STEP_STAY_BRANCH;
      endif
      :STR_RTDEC_STEP_BLEND;
      :score_m = Σ q[i]·v_m[i]\n+ w_fit·fit_m + w_hot·hot_m;
      -> vector_done;
    endif
  endif
endif

label r5_path
:STR_RTDEC_STEP_AXIS_TO_PRIORS;
:STR_RTDEC_STEP_SCORE_R5;
label vector_done
:STR_RTDEC_STEP_FILTER_RANK;
:STR_RTDEC_STEP_BUILD_RESP;

stop

note right
  STR_RTDEC_NOTE_FINAL_L1
  STR_RTDEC_NOTE_FINAL_L2
  STR_RTDEC_NOTE_FINAL_L3
  STR_RTDEC_NOTE_FINAL_L4
  STR_RTDEC_NOTE_FINAL_L5
end note

@enduml
