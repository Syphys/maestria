@startuml activity-characterization-escalation
!include ../_includes/style.iuml

title STR_CHESC_TITLE

' Slice 6a Dββ — only R5-maximal branches are deepened on the tree.
' This activity diagram shows the decision points + the failure
' isolation between passes.

start
:STR_CHESC_STEP_START;

partition "STR_CHESC_PART_PRELAUNCH" {
  :STR_CHESC_STEP_READ_HDR;
  if (STR_CHESC_IF_ARCH_NON_GEN) then (STR_CHESC_YES)
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (STR_CHESC_IF_NAME_REGEX) then (STR_CHESC_YES)
    note right
      STR_CHESC_NOTE_COSY_L1
      STR_CHESC_NOTE_COSY_L2
      STR_CHESC_NOTE_COSY_L3
      STR_CHESC_NOTE_COSY_L4
    end note
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (STR_CHESC_IF_POOLING) then (STR_CHESC_YES)
    :STR_CHESC_STEP_THROW_EMB;
    :state = 'failed' (quarantined);
    stop
  endif
}

:STR_CHESC_STEP_ENSURE_CHAT;
:STR_CHESC_STEP_ARCHIVE_LOG;

partition "STR_CHESC_PART_R5" {
  :STR_CHESC_STEP_ITER_PROMPTS;
  repeat
    :STR_CHESC_STEP_ASK;
    :STR_CHESC_STEP_EMIT_DONE;
    :STR_CHESC_STEP_RUN_SCORER;
    :STR_CHESC_STEP_UPD_AXIS;
    if (STR_CHESC_IF_TIER3) then (STR_CHESC_YES)
      note right
        STR_CHESC_NOTE_TIER3_L1
        STR_CHESC_NOTE_TIER3_L2
        STR_CHESC_NOTE_TIER3_L3
        STR_CHESC_NOTE_TIER3_L4
      end note
      :throw 'non-chat model';
      :state = 'failed' (quarantined);
      stop
    endif
  repeat while (STR_CHESC_WHILE_MORE) is (STR_CHESC_YES)
  -> STR_CHESC_ARR_R5_DONE;
  :STR_CHESC_STEP_PERSIST_BEHAV;
}

if (STR_CHESC_IF_TREE_AVAIL) then (STR_CHESC_NO)
  :STR_CHESC_STEP_STATE_INC;
  stop
endif

partition "STR_CHESC_PART_TREE" {
  :STR_CHESC_STEP_READ_AXIS;
  :STR_CHESC_STEP_BRANCH_GATE;
  fork
    :STR_CHESC_STEP_FOR_OPEN;
    :STR_CHESC_STEP_CHAR_BRANCH;
    if (passes_per_leaf > 0?) then (STR_CHESC_YES)
      :STR_CHESC_STEP_BETA_POST;
    else (STR_CHESC_NO)
      :STR_CHESC_STEP_MARK_UNMEAS;
    endif
  fork again
    :STR_CHESC_STEP_FOR_CLOSED;
    :Skip (cost-bounded);
    :STR_CHESC_STEP_LEAVES_QCM;
  end fork
  :STR_CHESC_STEP_MERGE_BEHAV;
  if (STR_CHESC_IF_TREE_FAIL) then (STR_CHESC_YES)
    :STR_CHESC_STEP_LOG_KEEP_R5;
    :state = 'incomplete';
    stop
  endif
}

partition "STR_CHESC_PART_FG1" {
  if (opts.freegen !== false?) then (STR_CHESC_NO)
    :STR_CHESC_STEP_SKIP_SILENT;
  else (STR_CHESC_YES)
    if (generateFreeGenText) then (STR_CHESC_SUCCEEDS)
      :STR_CHESC_STEP_ASK_FREEGEN;
      :Strip <think>…</think> (D11);
      :STR_CHESC_STEP_PERSIST_FG;
    else (STR_CHESC_THROWS)
      :STR_CHESC_STEP_LOG_SKIP_FG;
    endif
  endif
}

:state = 'complete';
:STR_CHESC_STEP_PERSIST_SIG;
:STR_CHESC_STEP_STOP_SRV;

partition "STR_CHESC_PART_FG2" {
  if (STR_CHESC_IF_SKIP_PROJ) then (STR_CHESC_YES)
    :STR_CHESC_STEP_DEFER_PROJ;
  else (STR_CHESC_NO)
    :STR_CHESC_STEP_EMBED_CLI;
    :STR_CHESC_STEP_PROJECT;
    :STR_CHESC_STEP_PATCH_SIG;
  endif
}

:STR_CHESC_STEP_REFRESH_RADAR;
stop

note right
  STR_CHESC_NOTE_FINAL_L1
  STR_CHESC_NOTE_FINAL_L2
  STR_CHESC_NOTE_FINAL_L3
  STR_CHESC_NOTE_FINAL_L4
  STR_CHESC_NOTE_FINAL_L5
  STR_CHESC_NOTE_FINAL_L6
  STR_CHESC_NOTE_FINAL_L7
  STR_CHESC_NOTE_FINAL_L8
  STR_CHESC_NOTE_FINAL_L9
  STR_CHESC_NOTE_FINAL_L10
end note

@enduml
