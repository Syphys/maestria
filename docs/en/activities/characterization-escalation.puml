@startuml activity-characterization-escalation
!include ../_includes/style.iuml

title Activity — characterization escalation\nR5 → tree → freegen with R5-gated deepening

' Slice 6a Dββ — only R5-maximal branches are deepened on the tree.
' This activity diagram shows the decision points + the failure
' isolation between passes.

start
:User clicks "Caractériser"\nOR MCP request;

partition "Pre-launch non-chat filter (2026-05-24)" {
  :Read GGUF header ONCE
  (arch + general.name + pooling);
  if (arch ∈ NON_GENERATIVE_ARCH?
    whisper/clip/bert/t5/...
    + qwen3tts/outetts/parlertts/
    kokoro/mossttts/snactts) then (yes)
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (general.name matches
    /[_\W](tokenizer|codec|vocoder|
    vq|cfm|tts)[_\W]/i ?) then (yes)
    note right
      Cosyvoice3 = name
      "Llamacpp_Tokenizer"
      → caught here, never
      boots llama-server.
    end note
    :throw UnsupportedModelError;
    :state = 'failed' (quarantined);
    stop
  endif
  if (pooling_type ≥ 1?
    Qwen3-Embedding-N etc.) then (yes)
    :throw UnsupportedModelError
    ("embedding model");
    :state = 'failed' (quarantined);
    stop
  endif
}

:characterizeRunner ensures\nchat process live;
:archiveServerLog
(rotate previous .log →
 .ts/<file>.<ISO>.log,
 fresh session starts clean);

partition "R5 pass (coarse, always)" {
  :Iterate v1-30.json prompts;
  repeat
    :ask.complete(prompt)
    (no client timeout — wait
     as long as the model needs);
    :emit prompt_done event
    with FULL DiagnosticRunEntry
    (live Interactions tab,
     2026-05-24);
    :Run registered scorer;
    :Update scores_per_axis;
    if (Tier 3 — adaptive quarantine?
      response only `<|stop_…|>` tokens
      OR 5 consecutive empties) then (yes)
      note right
        Catches TTS / audio-codec
        GGUFs the arch+name filters
        missed (e.g. a Cosyvoice
        variant with an innocent
        general.name).
      end note
      :throw 'non-chat model';
      :state = 'failed' (quarantined);
      stop
    endif
  repeat while (more prompts?) is (yes)
  -> R5 done;
  :Persist behavioral\n+ characterization_state = 'incomplete';
}

if (characterizeTreeFn available?) then (no)
  :State stays 'incomplete';
  stop
endif

partition "Tree pass (R5-gated, Dββ)" {
  :Read scores_per_axis;
  :branchGateFromAxes()\nmaps R5 → 9 branches;
  fork
    :For each branch where\n  R5 mapped score ≥ θ_open;
    :characterizeBranch\n(Phase A: level 1 probe,\nthen climb until first fail);
    if (passes_per_leaf > 0?) then (yes)
      :Beta-Laplace posterior\n(1+passes)/(2+asked);
    else (no)
      :Mark UNMEASURED\n→ branch prior D12;
    endif
  fork again
    :For each branch where R5 < θ_open;
    :Skip (cost-bounded);
    :Leaves stay at\nQCM-prior (qcmDiscount · pass);
  end fork
  :Merge into BehavioralSignature\n(scores_per_leaf, branch_scores,\npasses_per_leaf, n_per_leaf);
  if (tree pass failed catastrophically?) then (yes)
    :Log + KEEP R5 result;
    :state = 'incomplete';
    stop
  endif
}

partition "Free-gen PHASE 1 — text only (2026-05-22 split)" {
  if (opts.freegen !== false?) then (no)
    :Skip silently;
  else (yes)
    if (generateFreeGenText) then (succeeds)
      :ask.complete(FREEGEN_PROMPT)\n~600-800 words\nNO embedder needed;
      :Strip <think>…</think> (D11);
      :Persist freegen_text + freegen_words;
    else (throws)
      :Log + skip (DCC §5\nisolation: tree kept);
    endif
  endif
}

:state = 'complete';
:Persist signature (test pass done);
:Stop test server\n(release model RAM);

partition "Free-gen PHASE 2 — projection (per model, single-pass)" {
  if (opts.skipProjection OR\nembedder unreachable?) then (yes)
    :Defer projection\n(text already saved);
  else (no)
    :embedderCli.embedViaLlamaCli\n(spawn llama-embedding.exe,\nbatch text + 17 anchors,\nJSON out, process exits);
    :projectFreeGenText\n(cosine projection);
    :Patch signature:\ntopic_coverage_per_leaf,\ntopic_coverage_per_branch;
  endif
}

:Refresh UI radar (R5 + tree + projection);
stop

note right
  Three independent passes,
  each fail-isolated from the
  next. The strongest guarantee
  is: a working R5 always lands
  even if tree + freegen die.
  Free-gen split (2026-05-22) lets
  phase 1 always run (no embedder
  dependency); phase 2 can be
  deferred or done later on stored
  text without re-launching the
  test model.
end note

@enduml
