' Partial — MCP server stack. Included by any composer that draws
' the MCP layer.

package "src/main/modelhub/mcp/" <<Folder>> as PKG_MCP {
  component "STR_MCP_STACK_CMP_INDEX" as CMP_MCP_INDEX
  component "STR_MCP_STACK_CMP_SERVER" as CMP_MCP_SERVER
  component "STR_MCP_STACK_CMP_REG" as CMP_MCP_REG
  component "STR_MCP_STACK_CMP_TOKEN" as CMP_MCP_TOKEN
  component "STR_MCP_STACK_CMP_LOG" as CMP_MCP_LOG

  package "STR_MCP_STACK_PKG_TOOLS_LABEL" as PKG_MCP_TOOLS {
    component "STR_MCP_STACK_CMP_T_MODELS" as CMP_T_MODELS
    component "route.ts\n1 tool (models.route)" as CMP_T_ROUTE
    component "tags.ts\n2 tools" as CMP_T_TAGS
    component "description.ts\n2 tools" as CMP_T_DESC
    component "hardware.ts\n2 tools (detect/autotune)" as CMP_T_HW
    component "characterize.ts\n6 tools\n  · start/status/\n    all_start/cancel/\n    load_signature/\n    get_questions_dir" as CMP_T_CHAR
    component "logs.ts\n4 tools\n  · models.get_server_log\n  · get_error_log\n  · list_archives\n  · runners.get_log" as CMP_T_LOGS
    component "STR_MCP_STACK_CMP_T_META" as CMP_T_META
    component "discovery.ts\n2 tools\n  · sum_shard_bytes\n  · list_hosting_folders" as CMP_T_DISC
    component "STR_MCP_STACK_CMP_T_RUNN" as CMP_T_RUNN
    component "STR_MCP_STACK_CMP_T_CFG" as CMP_T_CFG
  }
}

component "STR_MCP_STACK_CMP_USE" as CMP_MCP_USE

CMP_MCP_INDEX ..> CMP_T_MODELS : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_ROUTE  : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_TAGS   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_DESC   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_HW     : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_CHAR   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_LOGS   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_META   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_DISC   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_RUNN   : import (side-effect)
CMP_MCP_INDEX ..> CMP_T_CFG    : import (side-effect)

CMP_MCP_SERVER --> CMP_MCP_REG : dispatch (ctx.isAdmin)
CMP_MCP_SERVER --> CMP_MCP_TOKEN : STR_MCP_STACK_REL_VERIFY_BEARER
CMP_MCP_SERVER --> CMP_MCP_LOG : STR_MCP_STACK_REL_APPEND_LOG
CMP_MCP_REG --> CMP_T_MODELS
CMP_MCP_REG --> CMP_T_ROUTE
CMP_MCP_REG --> CMP_T_TAGS
CMP_MCP_REG --> CMP_T_DESC
CMP_MCP_REG --> CMP_T_HW
CMP_MCP_REG --> CMP_T_CHAR
CMP_MCP_REG --> CMP_T_LOGS
CMP_MCP_REG --> CMP_T_META
CMP_MCP_REG --> CMP_T_DISC
CMP_MCP_REG --> CMP_T_RUNN
CMP_MCP_REG --> CMP_T_CFG

CMP_MCP_USE ..> CMP_MCP_INDEX : STR_MCP_STACK_REL_USE_INDEX
