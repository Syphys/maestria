!define STR_SBXDIA_TITLE Sandbox — isolation tests-code slice 2d (Dαα, opt-in, fail-closed)
!define STR_SBXDIA_IDX index.ts\n• getSandbox({enabled})\n• dispatch par\n  process.platform
!define STR_SBXDIA_UNSAFE unsafe.ts\n• UnsafeSandbox\n• throw à chaque fois\n• défaut quand opt-in off
!define STR_SBXDIA_POSIX posix.ts\n• PosixSandbox\n• rlimits NPROC=cur,\n  AS/DATA=512 MiB,\n  CPU=10s, FSIZE=0\n• pgrp détaché\n• kill -pgid sur timeout\n• `python -I -S -B`
!define STR_SBXDIA_WIN windows.ts\n• WindowsSandbox\n• dispatche vers PS1
!define STR_SBXDIA_PS1 win-job.ps1\n• Add-Type P/Invoke\n• CreateJobObject\n• ActiveProcessLimit=1\n• ProcessMemoryLimit\n  =512 MiB\n• KILL_ON_JOB_CLOSE\n• streams marker-line
!define STR_SBXDIA_RUNNER characterizeRunner.ts\n(construit le seam runSandbox)
!define STR_SBXDIA_STAIR staircase.evaluateItem()\n(catch le throw ⇒ UNMEASURED)
!define STR_SBXDIA_REL_UNSAFE enabled:false\n(défaut) OU\nOS inconnu
!define STR_SBXDIA_PY_LABEL python3\n(enfant)
!define STR_SBXDIA_PYEXE_LABEL python.exe\n(enfant)
!define STR_SBXDIA_REL_UNSAFE_STAIR throw\nSandboxUnavailable
!define STR_SBXDIA_REL_POSIX_STAIR {pass:bool} OU\nthrow sur\nUNMEASURED
!define STR_SBXDIA_REL_WIN_STAIR {pass:bool} OU\nthrow sur\nUNMEASURED
!define STR_SBXDIA_NOTE_IDX_L1 Fail-closed (Dαα §3) :
!define STR_SBXDIA_NOTE_IDX_L2 TOUTE impossibilité d'établir
!define STR_SBXDIA_NOTE_IDX_L3 la frontière kernel ⇒ throw
!define STR_SBXDIA_NOTE_IDX_L4 SandboxUnavailable ⇒ l'appelant
!define STR_SBXDIA_NOTE_IDX_L5 marque l'item UNMEASURED.
!define STR_SBXDIA_NOTE_IDX_L6 **Jamais** un faux pass.
!define STR_SBXDIA_NOTE_POSIX_L1 Préambule défense-en-profondeur bloque
!define STR_SBXDIA_NOTE_POSIX_L2 les imports (socket, subprocess,
!define STR_SBXDIA_NOTE_POSIX_L3 ctypes, …) — trivialement contournable,
!define STR_SBXDIA_NOTE_POSIX_L4 les rlimits SONT la frontière.

