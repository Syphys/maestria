!define STR_SIGLC_DESC_COMPLETE éligible au routing (D9).\nTous les champs comportementaux\nrequis présents : `scores_per_axis`,\n`scores_per_leaf`, `branch_scores`.\nmodels.route classe ce candidat.
!define STR_SIGLC_DESC_INCOMPLETE éligible au routing (D9) ssi\nle scores_per_axis core est posé.\nChamps optionnels manquants ⇒\nconfiance dégradée mais classé.
!define STR_SIGLC_DESC_QUARANTINED routing INÉLIGIBLE.\nMontré dans le radar avec une\nbannière claire. L'utilisateur\nre-caractérise pour quitter cet état.
!define STR_SIGLC_REL_RECHAR_CONFIRM Re-caractériser\n(avec confirm)
!define STR_SIGLC_REL_HASH_DRIFT drift modelHash\n(fichier édité /\nshards changés)
!define STR_SIGLC_REL_HASH_DRIFT_SHORT drift modelHash
!define STR_SIGLC_DESC_STALE Pseudo-état : hash sur disque ≠\nhash fichier courant. Le routing\nutilise encore l'ancienne signature mais\nl'UI prompt une re-caractérisation.
!define STR_SIGLC_NOTE_QUAR_L1 Quarantined reste permanent
!define STR_SIGLC_NOTE_QUAR_L2 jusqu'à ce que l'utilisateur
!define STR_SIGLC_NOTE_QUAR_L3 re-caractérise explicitement — même
!define STR_SIGLC_NOTE_QUAR_L4 si une query de routing arrive.
!define STR_SIGLC_NOTE_RUN_L1 Effets de bord sur disque :
!define STR_SIGLC_NOTE_RUN_L2 • `archiveServerLog(...)` au DÉBUT du run
!define STR_SIGLC_NOTE_RUN_L3   (renomme le `.log` précédent →
!define STR_SIGLC_NOTE_RUN_L4   `.<ISO>.log`, session fraîche
!define STR_SIGLC_NOTE_RUN_L5   commence propre — 2026-05-24).
!define STR_SIGLC_NOTE_RUN_L6 • `appendServerLog(.log, chunk)`
!define STR_SIGLC_NOTE_RUN_L7   sur chaque chunk stdout/stderr de
!define STR_SIGLC_NOTE_RUN_L8   llama-server (hooké dans runners/launch.ts).
!define STR_SIGLC_NOTE_RUN_L9 • Sur Quarantined / Incomplete-avec-erreur :
!define STR_SIGLC_NOTE_RUN_L10   `appendErrorLog(.ts/<fichier>.error, raison)` avec timestamp ISO.

