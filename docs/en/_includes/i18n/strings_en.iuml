!define STR_CHARDIA_PEND_SCORERS sandbox-pending\nscorers\n(code-debug/fim/refactor)\n→ slice 2d
!define STR_CHARDIA_FREEGEN freegen.ts\n(2-phase, 2026-05-22)\n• generateFreeGenText\n  (chat only, no embedder)\n• projectFreeGenText\n  (embedder only)
