!define STR_SIGLC_REL_HASH_DRIFT_SHORT modelHash drift
!define STR_SIGLC_DESC_STALE Pseudo-state: hash on disk ≠\ncurrent file hash. Routing\nstill uses old signature but\nUI prompts re-characterization.
