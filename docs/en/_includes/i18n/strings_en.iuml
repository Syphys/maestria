!define STR_CHARDIA_REL_ALL_RUNNER per model:\nfull / gen / project-only
!define STR_CHARDIA_REL_ALL_EMB resolveEmbedderCliFn()\n(once at bulk start)
!define STR_CHARDIA_REL_ALL_FG runFreeGenProject\n(per-model after test)
!define STR_CHARDIA_REL_R5 R5 first\n(coarse pass)
!define STR_CHARDIA_REL_TREE then tree\n(fine pass, R5-gated)
!define STR_CHARDIA_REL_TREE_FG generateFreeGenText\n(phase 1 only — embed undefined)
!define STR_CHARDIA_REL_TREE_STAIR per branch\n(opened only)
!define STR_CHARDIA_REL_PEND_SBX `runSandbox` seam\n(slice 2d)
!define STR_CHARDIA_REL_TREE_STORE merge tree fields\n(scores_per_leaf,\nbranch_scores,\npasses_per_leaf,\nfreegen_text)
!define STR_CHARDIA_REL_FG_STORE patch with\ntopic_coverage_*
!define STR_CHARDIA_REL_ALL_LOG appendErrorLog(file, reason)
!define STR_CHARDIA_REL_RUNNER_LOG appendServerLog\n(via launch.ts logChunk hook)
!define STR_CHARDIA_NOTE_RUNNER_L1 Failure-isolated:
!define STR_CHARDIA_NOTE_RUNNER_L2 R5 ✓ even if tree fails;
!define STR_CHARDIA_NOTE_RUNNER_L3 tree ✓ even if freegen fails;
!define STR_CHARDIA_NOTE_RUNNER_L4 staircase ✓ even if a leaf
!define STR_CHARDIA_NOTE_RUNNER_L5 goes UNMEASURED (D12 prior);
!define STR_CHARDIA_NOTE_RUNNER_L6 log/error append is best-effort
!define STR_CHARDIA_NOTE_RUNNER_L7 (a disk error never sinks a run).
!define STR_CHARDIA_NOTE_STAIR_L1 étape 1 (Beta-Laplace):
!define STR_CHARDIA_NOTE_STAIR_L3 3/3 ⇒ 0.80, never 1.0 in Phase A.
!define STR_CHARDIA_NOTE_STAIR_L4 Phase B saturation = deferred.
!define STR_CHARDIA_NOTE_ALL_L1 Single-pass loop, per model:
!define STR_CHARDIA_NOTE_ALL_L2 1. test (llama-server, no embedder)
!define STR_CHARDIA_NOTE_ALL_L3 2. if freegen_text present
!define STR_CHARDIA_NOTE_ALL_L4 AND skipProjection=false
!define STR_CHARDIA_NOTE_ALL_L5 AND embedder available
!define STR_CHARDIA_NOTE_ALL_L6 → spawn llama-embedding (CLI),
!define STR_CHARDIA_NOTE_ALL_L7 project, exit.
