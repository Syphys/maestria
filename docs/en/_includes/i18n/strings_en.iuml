!define STR_SBXDIA_REL_WIN_STAIR {pass:bool} OR\nthrows on\nUNMEASURED
!define STR_SBXDIA_NOTE_IDX_L1 Fail-closed (Dαα §3):
!define STR_SBXDIA_NOTE_IDX_L2 ANY impossibility to set the
!define STR_SBXDIA_NOTE_IDX_L3 kernel boundary ⇒ throw
!define STR_SBXDIA_NOTE_IDX_L4 SandboxUnavailable ⇒ caller
!define STR_SBXDIA_NOTE_IDX_L5 marks the item UNMEASURED.
!define STR_SBXDIA_NOTE_IDX_L6 **Never** a false pass.
!define STR_SBXDIA_NOTE_POSIX_L1 Defense-in-depth preamble blocks
!define STR_SBXDIA_NOTE_POSIX_L2 imports (socket, subprocess,
!define STR_SBXDIA_NOTE_POSIX_L3 ctypes, …) — trivially bypassable,
!define STR_SBXDIA_NOTE_POSIX_L4 the rlimits ARE the boundary.

