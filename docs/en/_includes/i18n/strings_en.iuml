!define STR_EMBPROC_DESC_WAITING loop until\n• response.ok ⇒ Ready\n• entry.exited ⇒ Crashed\n• 60 s deadline ⇒ Timeout\nPolls every 1 s with 4 s budget per probe.
!define STR_EMBPROC_REL_EXIT_BOOT process exited\nduring boot
!define STR_EMBPROC_REL_DEADLINE 60 s deadline
!define STR_EMBPROC_DESC_READY return {baseUrl, pid,\nsource:'launched'}.\nVisible in RunningModelsPanel\nunder "embedder" group.
!define STR_EMBPROC_DESC_CRASHED stopProcess(pid),\nreturn null,\nclear in-flight promise.\nCaller silently falls back to R5.
!define STR_EMBPROC_DESC_TIMEDOUT stopProcess(pid),\nreturn null,\nclear in-flight promise.\nCaller silently falls back to R5.
!define STR_EMBPROC_DESC_FAILED log + return null,\nclear in-flight promise.\nCaller silently falls back to R5.
!define STR_EMBPROC_REL_STOP stopManagedEmbedders()\nor process killed manually
!define STR_EMBPROC_REL_SUBSEQ subsequent\nensureEmbedderReady\n(idempotent)
!define STR_EMBPROC_NOTE_LAUNCH_L1 Concurrent callers share the SAME
!define STR_EMBPROC_NOTE_LAUNCH_L2 in-flight promise — never spawn
!define STR_EMBPROC_NOTE_LAUNCH_L3 twice. This is the only critical
!define STR_EMBPROC_NOTE_LAUNCH_L4 section in embedderLifecycle.ts.

