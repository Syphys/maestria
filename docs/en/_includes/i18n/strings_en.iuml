' === objects/characterized-model.puml ===
!define STR_OCHAR_TITLE Object diagram — a fully characterized model in the sidecar
!define STR_OCHAR_HDR_TREE tree (slice 4c+)
!define STR_OCHAR_ABSENT_SBX (absent — UNMEASURED,\nsandbox opt-in off)
!define STR_OCHAR_RUN1_RESPONSE Train A had a head start of…
!define STR_OCHAR_RUN2_DETAIL UNMEASURED — sandbox opt-in off
!define STR_OCHAR_NOTE_BL_L1 Beta-Laplace example:
!define STR_OCHAR_NOTE_BL_L2 3/3 climb on `math.proba`
