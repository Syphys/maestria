@startuml states-signature-lifecycle
!include ../_includes/style.iuml

title STR_SIGLC_TITLE

' States are the literal values on disk in `.ts/<file>.json`.
' Transitions correspond to characterizeRunner.ts outcomes.
'
' Companion artifacts written next to the signature JSON:
'   - `.ts/<file>.log`              — active session: llama-server
'                                     stdout/stderr captured on every
'                                     Maestria-managed launch
'                                     (append-only, 4 MiB rotation).
'   - `.ts/<file>.<YYYYMMDDThhmmssZ>.log`
'                                   — per-session archive (2026-05-24):
'                                     rotated from `.log` at the start
'                                     of each new characterization,
'                                     keeps last 10 sessions per model.
'   - `.ts/<file>.error`            — timestamped per-model error
'                                     journal from characterizeAll
'                                     (one line per failure).
' All best-effort writes: a disk error never sinks a run.

[*] --> NotCharacterized : STR_SIGLC_REL_MODEL_ADDED

state "STR_SIGLC_S_NOTCHAR" as NotCharacterized {
  description : STR_SIGLC_DESC_NOTCHAR
}

NotCharacterized --> Running : STR_SIGLC_REL_USER_CHAR

state "STR_SIGLC_S_RUNNING" as Running {
  description : STR_SIGLC_DESC_RUNNING
}

Running --> Complete : STR_SIGLC_REL_ALL_OK
Running --> Incomplete : STR_SIGLC_REL_TREE_FAIL
Running --> Quarantined : STR_SIGLC_REL_QUARANTINED

state "complete" as Complete #FFFDF6 {
  description : STR_SIGLC_DESC_COMPLETE
}

state "incomplete" as Incomplete {
  description : STR_SIGLC_DESC_INCOMPLETE
}

state "quarantined" as Quarantined #E6DFD2 {
  description : STR_SIGLC_DESC_QUARANTINED
}

Complete --> Running : STR_SIGLC_REL_RECHAR_CONFIRM
Incomplete --> Running : Re-caractériser
Quarantined --> Running : Re-caractériser
Complete --> Stale : STR_SIGLC_REL_HASH_DRIFT
Incomplete --> Stale : STR_SIGLC_REL_HASH_DRIFT_SHORT

state "Stale" as Stale {
  description : STR_SIGLC_DESC_STALE
}

Stale --> Running : Re-caractériser

note bottom of Quarantined
  STR_SIGLC_NOTE_QUAR_L1
  STR_SIGLC_NOTE_QUAR_L2
  STR_SIGLC_NOTE_QUAR_L3
  STR_SIGLC_NOTE_QUAR_L4
end note

note right of Running
  STR_SIGLC_NOTE_RUN_L1
  STR_SIGLC_NOTE_RUN_L2
  STR_SIGLC_NOTE_RUN_L3
  STR_SIGLC_NOTE_RUN_L4
  STR_SIGLC_NOTE_RUN_L5
  STR_SIGLC_NOTE_RUN_L6
  STR_SIGLC_NOTE_RUN_L7
  STR_SIGLC_NOTE_RUN_L8
  STR_SIGLC_NOTE_RUN_L9
  STR_SIGLC_NOTE_RUN_L10
end note

@enduml
