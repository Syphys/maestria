@startuml states-embedder-process
!include ../_includes/style.iuml

title STR_EMBPROC_TITLE

' Reflects the logic of embedderLifecycle.ts:
'   - in-flight launch promise = concurrency guard
'   - /v1/models polling = ready check, 60 s budget
'   - silent fallback on any failure (returns null, never throws)
'
' Scope: this is the SERVER mode (resident llama-server --embedding)
' used by interactive routing queries (routeByVectors).
' The CLI mode used by bulk characterization (embedderCli.ts) is NOT
' modelled here as a state machine — every call spawns a fresh
' llama-embedding.exe that exits at the end of the call, so the only
' meaningful states are { idle → spawned → exited } per invocation.
' See components/embedder.puml for the dual-mode component view.

[*] --> Idle

state "STR_EMBPROC_S_IDLE" as Idle {
  description : STR_EMBPROC_DESC_IDLE
}

Idle --> Probing : STR_EMBPROC_REL_ENSURE

state "STR_EMBPROC_S_PROBING" as Probing {
  description : STR_EMBPROC_DESC_PROBING
}

Probing --> Reused : STR_EMBPROC_REL_FOUND_ALIVE
Probing --> Launching : STR_EMBPROC_REL_NOTFOUND

state "STR_EMBPROC_S_REUSED" as Reused #FFFDF6 {
  description : STR_EMBPROC_DESC_REUSED
}

state "STR_EMBPROC_S_LAUNCHING" as Launching {
  description : launchModelByPath(\n  launchedBy:'embedder',\n  customArgs:'--embedding'\n)
}

Launching --> Waiting : STR_EMBPROC_REL_SPAWN_OK
Launching --> Failed : STR_EMBPROC_REL_SPAWN_NOK

state "STR_EMBPROC_S_WAITING" as Waiting {
  description : STR_EMBPROC_DESC_WAITING
}

Waiting --> Ready : 200 OK
Waiting --> Crashed : STR_EMBPROC_REL_EXIT_BOOT
Waiting --> TimedOut : STR_EMBPROC_REL_DEADLINE

state "Ready" as Ready #FFFDF6 {
  description : STR_EMBPROC_DESC_READY
}

state "Crashed" as Crashed {
  description : STR_EMBPROC_DESC_CRASHED
}

state "Timed out" as TimedOut {
  description : STR_EMBPROC_DESC_TIMEDOUT
}

state "Failed" as Failed {
  description : STR_EMBPROC_DESC_FAILED
}

Ready --> Idle : STR_EMBPROC_REL_STOP
Crashed --> Idle
TimedOut --> Idle
Failed --> Idle
Reused --> Reused : STR_EMBPROC_REL_SUBSEQ

note bottom of Launching
  STR_EMBPROC_NOTE_LAUNCH_L1
  STR_EMBPROC_NOTE_LAUNCH_L2
  STR_EMBPROC_NOTE_LAUNCH_L3
  STR_EMBPROC_NOTE_LAUNCH_L4
end note

@enduml
