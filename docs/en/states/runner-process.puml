@startuml states-runner-process
!include ../_includes/style.iuml

title STR_RUNPROC_TITLE

' Tracks an ActiveEntry through its lifecycle in runners/launch.ts.
' Same state machine for chat models AND for the managed embedder —
' the only difference is `launchedBy` and `customArgs`.

[*] --> Requested

state "Requested" as Requested {
  description : STR_RUNPROC_DESC_REQUESTED
}

Requested --> Validating : args + path OK
Requested --> RejectedEarly : STR_RUNPROC_REL_REJ_EARLY1

state "Validating" as Validating {
  description : STR_RUNPROC_DESC_VALIDATING
}

Validating --> Spawning : STR_RUNPROC_REL_RUNNER_RESOLVED
Validating --> RejectedEarly : STR_RUNPROC_REL_REJ_EARLY2

state "Spawning" as Spawning {
  description : STR_RUNPROC_DESC_SPAWNING
}

Spawning --> Booting : STR_RUNPROC_REL_PID_RECV
Spawning --> CrashedEarly : STR_RUNPROC_REL_SPAWN_ERR

state "Booting" as Booting {
  description : STR_RUNPROC_DESC_BOOTING
}

Booting --> Live : STR_RUNPROC_REL_POLL_OK
Booting --> CrashedEarly : STR_RUNPROC_REL_EARLY_EXIT

state "Live" as Live #FFFDF6 {
  description : STR_RUNPROC_DESC_LIVE
}

Live --> Live : STR_RUNPROC_REL_LIST_RUNNING
Live --> Stopping : STR_RUNPROC_REL_STOP_OR

state "Stopping" as Stopping {
  description : STR_RUNPROC_DESC_STOPPING
}

Stopping --> Exited

state "Exited" as Exited {
  description : STR_RUNPROC_DESC_EXITED
}

Exited --> [*] : STR_RUNPROC_REL_CLEARED
RejectedEarly --> [*]
CrashedEarly --> Exited

note bottom of Live
  STR_RUNPROC_NOTE_LIVE_L1
  STR_RUNPROC_NOTE_LIVE_L2
  STR_RUNPROC_NOTE_LIVE_L3
  STR_RUNPROC_NOTE_LIVE_L4
end note

@enduml
