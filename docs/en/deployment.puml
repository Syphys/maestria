@startuml deployment
!include _includes/style.iuml
!include _includes/actors.iuml

title STR_DEPL_TITLE

node "STR_DEPL_HOST" as HOST {
  node "STR_DEPL_MAESTRIA" as MAESTRIA {
    component "STR_DEPL_R" as R
    component "STR_DEPL_M" as M
  }

  node "STR_DEPL_SUBS" as SUBS {
    node "STR_DEPL_P_CHAT" as P_CHAT
    node "llama-server\n--embedding\nport 8081" as P_EMB
    node "STR_DEPL_P_PY" as P_PY
  }

  database "STR_DEPL_FS_LABEL" {
    folder "STR_DEPL_MODELS" as MODELS
    folder "STR_DEPL_SC" as SC
    folder "STR_DEPL_APPDATA" as APP_DATA
  }
}

node "STR_DEPL_EXT_CLIENTS" as EXT_CLIENTS {
  component "Claude Code" as C_CC
  component "Cursor" as C_CUR
  component "deer-flow" as C_DF
  component "bash / curl" as C_SH
}

USER --> R : STR_DEPL_REL_USER_R
M --> P_CHAT : spawn / stop
M --> P_EMB : spawn / stop\n(slice 7e)
M --> P_PY : STR_DEPL_REL_M_PPY
M --> SC : STR_DEPL_REL_M_SC
M --> MODELS : STR_DEPL_REL_M_MODELS
M --> APP_DATA : STR_DEPL_REL_M_APP

EXT_CLIENTS -- M : HTTP+SSE\n127.0.0.1:41541\nBearer token
R -- M : STR_DEPL_REL_R_M

note right of P_CHAT
  STR_DEPL_NOTE_PCHAT_L1
  STR_DEPL_NOTE_PCHAT_L2
  STR_DEPL_NOTE_PCHAT_L3
end note

note right of P_EMB
  Singleton — `launchedBy: 'embedder'`.
  STR_DEPL_NOTE_PEMB_L2
end note

note right of P_PY
  STR_DEPL_NOTE_PPY_L1
  STR_DEPL_NOTE_PPY_L2
  STR_DEPL_NOTE_PPY_L3
end note

note bottom of EXT_CLIENTS
  STR_DEPL_NOTE_EXT_L1
  STR_DEPL_NOTE_EXT_L2
  STR_DEPL_NOTE_EXT_L3
  STR_DEPL_NOTE_EXT_L4
end note

@enduml
