@startuml competence-tree
!include ../_includes/style.iuml

' DRY composer — the tree taxonomy (CompetenceBranch type +
' COMPETENCE_TREE constant + the 9-branch visual) lives in
' _includes/classes/competence-tree.iuml so any other diagram that
' wants to reference it can `!include` the partial.

!include ../_includes/classes/competence-tree.iuml

title STR_CTREE_DIAG_TITLE

note right of B_SAFE
  STR_CTREE_DIAG_NOTE_SAFE_L1
  STR_CTREE_DIAG_NOTE_SAFE_L2
  STR_CTREE_DIAG_NOTE_SAFE_L3
end note

note right of B_INFO
  STR_CTREE_DIAG_NOTE_INFO_L1
  STR_CTREE_DIAG_NOTE_INFO_L2
end note

note right of B_TOOLS
  STR_CTREE_DIAG_NOTE_TOOLS_L1
  STR_CTREE_DIAG_NOTE_TOOLS_L2
  STR_CTREE_DIAG_NOTE_TOOLS_L3
end note

note bottom of B_LANG
  STR_CTREE_DIAG_NOTE_LANG_L1
  STR_CTREE_DIAG_NOTE_LANG_L2
  STR_CTREE_DIAG_NOTE_LANG_L3
end note

@enduml
