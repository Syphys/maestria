@startuml sandbox-providers
!include ../_includes/style.iuml

' DRY composer — every class definition lives in its own partial under
' _includes/classes/. This file ONLY assembles the picture (includes +
' inheritance arrows + factory dependencies + a single explanatory
' note). Any other diagram that wants to reference, say, `SandboxProvider`
' should `!include _includes/classes/sandbox-types.iuml` and reuse the
' SAME class — never redeclare.

!include ../_includes/classes/sandbox-types.iuml
!include ../_includes/classes/sandbox-unsafe.iuml
!include ../_includes/classes/sandbox-posix.iuml
!include ../_includes/classes/sandbox-windows.iuml
!include ../_includes/classes/sandbox-index.iuml

title STR_SBXPROV_TITLE

SandboxProvider <|-- UnsafeSandbox
SandboxProvider <|-- PosixSandbox
SandboxProvider <|-- WindowsSandbox
SandboxProvider ..> SandboxResult : STR_SBXPROV_REL_RETURNS
SandboxProvider ..> SandboxOptions : STR_SBXPROV_REL_ACCEPTS
SandboxProvider ..> SandboxUnavailable : STR_SBXPROV_REL_THROWS

PosixSandbox ..> Spawner : STR_SBXPROV_REL_INJECTS
WindowsSandbox ..> Spawner : STR_SBXPROV_REL_INJECTS
WindowsSandbox ..> PS1 : spawn powershell.exe

GetSandbox ..> UnsafeSandbox : STR_SBXPROV_REL_DISP_UNSAFE
GetSandbox ..> PosixSandbox : enabled:true\n+ linux/darwin
GetSandbox ..> WindowsSandbox : enabled:true\n+ win32

note bottom of GetSandbox
  STR_SBXPROV_NOTE_L1
  STR_SBXPROV_NOTE_L2
  STR_SBXPROV_NOTE_L3
  STR_SBXPROV_NOTE_L4
end note

@enduml
