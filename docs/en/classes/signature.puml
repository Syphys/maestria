@startuml signature
!include ../_includes/style.iuml
!include ../_includes/legend.iuml

' DRY composer — the class definitions live in
' _includes/classes/routing-types.iuml. Any other diagram that needs
' to reference these shapes (`Signature`, `BehavioralSignature`, …)
' should `!include` the SAME partial — never redeclare.

!include ../_includes/classes/routing-types.iuml

title STR_SIGNATURE_TITLE

' Persistence side — kept inline because it's diagram-specific (a
' different composer might show signatureStore behaviour without the
' on-disk database). `component` declarations would clash with the
' class-diagram mode the routing-types include puts us in, so we
' use the class shape here too (visually identical, parser-stable).
class "STR_SIGNATURE_STORE_LABEL" as STORE
class "STR_SIGNATURE_DISK_LABEL" as DISK <<file>>

Signature *-- StructuralSignature
Signature *-- BehavioralSignature
Signature *-- QcmReliability
BehavioralSignature *-- "STR_SIGNATURE_MULT_MANY" DiagnosticRunEntry
STORE ..> Signature : STR_SIGNATURE_REL_SERIALISE
STORE -- DISK : JSON

note right of BehavioralSignature::scores_per_leaf
  STR_SIGNATURE_NOTE_LEAF_L1
  STR_SIGNATURE_NOTE_LEAF_L2
  STR_SIGNATURE_NOTE_LEAF_L3
end note

note right of BehavioralSignature::topic_coverage_per_leaf
  STR_SIGNATURE_NOTE_COV_L1
  STR_SIGNATURE_NOTE_COV_L2
  STR_SIGNATURE_NOTE_COV_L3
  STR_SIGNATURE_NOTE_COV_L4
end note

note bottom of QcmReliability
  STR_SIGNATURE_NOTE_QCM_L1
  STR_SIGNATURE_NOTE_QCM_L2
  STR_SIGNATURE_NOTE_QCM_L3
end note

@enduml
