@startuml usecase-users
!include ../_includes/style.iuml
!include ../_includes/usecase/actors.iuml

title STR_UCU_TITLE

left to right direction

rectangle "STR_UCU_RECT_LABEL" {

  package "STR_UCU_PKG_UI" as UC_UI {
    usecase "STR_UCU_OPEN" as UC_OPEN
    usecase "STR_UCU_RUN" as UC_RUN
    usecase "STR_UCU_CH" as UC_CH
    usecase "STR_UCU_RADAR" as UC_RADAR
    usecase "STR_UCU_BULK" as UC_BULK
  }

  package "STR_UCU_PKG_SET" as UC_SET {
    usecase "STR_UCU_PICK_EMB" as UC_PICK_EMB
    usecase "STR_UCU_OPT_SBX" as UC_OPT_SBX
    usecase "STR_UCU_MCP" as UC_MCP
    usecase "STR_UCU_COPY_CFG" as UC_COPY_CFG
    usecase "Override hardware" as UC_HW
  }

  package "STR_UCU_PKG_MCP_SURF" as UC_MCP_SURF {
    usecase "models.search / .get" as UC_SEARCH
    usecase "models.run / .stop" as UC_MRUN
    usecase "STR_UCU_ROUTE" as UC_ROUTE
    usecase "models.get_run_params\nmodels.list_runner_flags" as UC_INSPECT
    usecase "tags.add / .remove" as UC_TAGS
    usecase "description.set / .get" as UC_DESC
    usecase "hardware.detect /\n.autotune" as UC_HW_TOOL
  }
}

A_USER --> UC_OPEN
A_USER --> UC_RUN
A_USER --> UC_CH
A_USER --> UC_RADAR
A_USER --> UC_BULK
A_USER --> UC_PICK_EMB
A_USER --> UC_OPT_SBX
A_USER --> UC_MCP
A_USER --> UC_COPY_CFG
A_USER --> UC_HW

A_MCP_CLI --> UC_SEARCH
A_MCP_CLI --> UC_MRUN
A_MCP_CLI --> UC_ROUTE
A_MCP_CLI --> UC_INSPECT
A_MCP_CLI --> UC_TAGS
A_MCP_CLI --> UC_DESC
A_MCP_CLI --> UC_HW_TOOL

UC_PICK_EMB ..> A_EXT_EMB : STR_UCU_REL_ALT
UC_ROUTE ..> UC_MRUN : STR_UCU_REL_EXTENDS
UC_INSPECT ..> UC_MRUN : <<precedes>>

note bottom of UC_OPT_SBX
  STR_UCU_NOTE_SBX_L1
  STR_UCU_NOTE_SBX_L2
  STR_UCU_NOTE_SBX_L3
  STR_UCU_NOTE_SBX_L4
end note

note bottom of UC_ROUTE
  STR_UCU_NOTE_ROUTE_L1
  STR_UCU_NOTE_ROUTE_L2
end note

@enduml
