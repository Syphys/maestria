@startuml characterization-flow
!include ../_includes/style.iuml

title STR_CFLOW_TITLE

actor STR_CFLOW_ACTOR_USER
participant "STR_CFLOW_UI" as UI
participant "characterizeRunner" as RUN
participant "runner registry\n+ launch.ts" as LAUNCH
participant "STR_CFLOW_LOG" as LOG
participant "llama-server\n(chat)" as CHAT
participant "STR_CFLOW_R5" as R5
participant "characterizeTree.ts" as TREE
participant "staircase.ts\n+ scorers" as STAIR
participant "sandbox\n(slice 2d)" as SBX
participant "STR_CFLOW_FG" as FG
participant "embedderCli.ts\n(llama-embedding,\none-shot)" as EMB_CLI
participant "STR_CFLOW_SIG" as SIG

STR_CFLOW_ACTOR_USER -> UI : "STR_CFLOW_MSG_CHAR"
UI -> RUN : start({filePath, freegen, skipProjection})

== STR_CFLOW_GRP_PRELAUNCH ==
RUN -> RUN : STR_CFLOW_MSG_READ_HDR
alt STR_CFLOW_ALT_NON_CHAT
  RUN -> SIG : STR_CFLOW_MSG_MARKUNSUP
  RUN --> UI : status:'error' (state='failed', quarantined)
  note right of RUN
    STR_CFLOW_NOTE_COSYV_L1
    STR_CFLOW_NOTE_COSYV_L2
    STR_CFLOW_NOTE_COSYV_L3
  end note
else STR_CFLOW_ELSE_GEN_OK
  RUN -> LOG : STR_CFLOW_MSG_ARCHIVE_LOG
  RUN -> LAUNCH : STR_CFLOW_MSG_ENSURE_CHAT
  LAUNCH -> CHAT : llama-server (8080)
  LAUNCH -> LOG : STR_CFLOW_MSG_APPEND_STREAMS
end
RUN -> R5 : STR_CFLOW_MSG_RUNR5
loop STR_CFLOW_LOOP_PROMPT
  R5 -> CHAT : prompt
  CHAT --> R5 : STR_CFLOW_MSG_CONTENT_REASONING
  R5 -> UI : STR_CFLOW_MSG_PROMPT_DONE
  alt STR_CFLOW_ALT_STOP_TOKENS
    R5 --> RUN : throw 'non-chat model'
    note right of R5
      STR_CFLOW_NOTE_TIER3_L1
      STR_CFLOW_NOTE_TIER3_L2
      STR_CFLOW_NOTE_TIER3_L3
      STR_CFLOW_NOTE_TIER3_L4
    end note
  end
end
R5 --> RUN : STR_CFLOW_MSG_BEHAV_R5

== STR_CFLOW_GRP_TREE ==
RUN -> TREE : characterizeTree({\n  ask, embed:undefined, seams.runSandbox\n})
note right of TREE
  STR_CFLOW_NOTE_TREE_L1
  STR_CFLOW_NOTE_TREE_L2
  STR_CFLOW_NOTE_TREE_L3
end note
loop STR_CFLOW_LOOP_BRANCH
  TREE -> STAIR : characterizeBranch(branch)
  loop STR_CFLOW_LOOP_LEAF
    STAIR -> CHAT : item.prompt
    CHAT --> STAIR : STR_CFLOW_MSG_RESPONSE
    alt STR_CFLOW_ALT_REG_SCORER
      STAIR -> STAIR : runCheck(response)
    else STR_CFLOW_ELSE_SBX_REQ
      STAIR -> SBX : runSandbox({code, tests})
      alt STR_CFLOW_ALT_OPTIN_OFF
        SBX --> STAIR : throw SandboxUnavailable
        STAIR -> STAIR : STR_CFLOW_MSG_MARK_UNMEAS
      else
        SBX -> SBX : STR_CFLOW_MSG_SPAWN_PY
        SBX --> STAIR : {pass:true|false}
      end
    end
  end
end
TREE --> RUN : scores_per_leaf,\nbranch_scores,\npasses_per_leaf

== STR_CFLOW_GRP_FG1 ==
alt freegen=true
  TREE -> FG : generateFreeGenText(ask)
  FG -> CHAT : FREEGEN_PROMPT
  CHAT --> FG : STR_CFLOW_MSG_FG_WORDS
  FG --> TREE : { text, words }
end

TREE --> RUN : STR_CFLOW_MSG_SIG_WITH_TEXT
RUN -> SIG : writeSignature(skipWrite?)
RUN -> LAUNCH : stop chat server
RUN --> UI : status:'tests done'

== STR_CFLOW_GRP_FG2 ==
note over RUN
  STR_CFLOW_NOTE_FG2_L1
  STR_CFLOW_NOTE_FG2_L2
  STR_CFLOW_NOTE_FG2_L3
end note
alt STR_CFLOW_ALT_PROJ_RUN
  RUN -> EMB_CLI : STR_CFLOW_MSG_EMBED_CALL
  EMB_CLI -> EMB_CLI : spawn llama-embedding.exe\n--embd-output-format json\n--log-disable
  EMB_CLI --> RUN : STR_CFLOW_MSG_FLOAT32_RAM
  RUN -> FG : projectFreeGenText(text, embed, anchors)
  FG --> RUN : STR_CFLOW_MSG_TOPIC_COV
  RUN -> SIG : STR_CFLOW_MSG_PATCH_SIG
else
  note right of RUN
    STR_CFLOW_NOTE_SKIP_L1
    STR_CFLOW_NOTE_SKIP_L2
    STR_CFLOW_NOTE_SKIP_L3
  end note
end

RUN --> UI : status:'done' + signature
UI -> UI : STR_CFLOW_MSG_REFRESH_RADAR

@enduml
