@startuml characterization-flow
!include ../_includes/style.iuml

title Characterise ONE model — full flow (2026-05-23 single-pass)

actor User
participant "UI\n(Inférence tab)" as UI
participant "characterizeRunner" as RUN
participant "runner registry\n+ launch.ts" as LAUNCH
participant "modelLogStore\n(.ts/<file>.log)" as LOG
participant "llama-server\n(chat)" as CHAT
participant "characterize.ts\n(R5 pass)" as R5
participant "characterizeTree.ts" as TREE
participant "staircase.ts\n+ scorers" as STAIR
participant "sandbox\n(slice 2d)" as SBX
participant "freegen.ts\n(2-phase, 2026-05-22)" as FG
participant "embedderCli.ts\n(llama-embedding,\none-shot)" as EMB_CLI
participant "signatureStore\n(.ts/<file>.json)" as SIG

User -> UI : "Caractériser" / "Re-caractériser"
UI -> RUN : start({filePath, freegen, skipProjection})

== Pre-launch non-chat filter (2026-05-24) ==
RUN -> RUN : readModelHeader(filePath) ONCE
alt arch ∈ NON_GENERATIVE_ARCH\nOR name matches /tokenizer|codec|vocoder|vq|cfm|tts/\nOR pooling_type ≥ 1
  RUN -> SIG : markUnsupported(reason)
  RUN --> UI : status:'error' (state='failed', quarantined)
  note right of RUN
    Cosyvoice3 = name "Llamacpp_Tokenizer"
    is caught HERE → no llama-server boot,
    no wasted 28-prompt suite.
  end note
else generative chat OK
  RUN -> LOG : archiveServerLog(filePath)\n(rotate prev .log → .ts/<file>.<ISO>.log)
  RUN -> LAUNCH : ensure chat live (spawn if needed)\nwith --timeout 86400
  LAUNCH -> CHAT : llama-server (8080)
  LAUNCH -> LOG : append stdout/stderr\n(append-only, 4 MiB rotation)
end
RUN -> R5 : runR5(ask=chatClient,\n  no wall-clock timeout)
loop per prompt (v1-30)
  R5 -> CHAT : prompt
  CHAT --> R5 : content (+ reasoning_content\n  wrapped as <think>…</think>\n  if model emits it)
  R5 -> UI : prompt_done event\nwith FULL DiagnosticRunEntry\n(live « Interactions » tab,\n2026-05-24)
  alt response = only `<|stop_…|>` tokens\nOR 5 consecutive empties
    R5 --> RUN : throw 'non-chat model'
    note right of R5
      Tier 3 adaptive quarantine —
      catches TTS / audio-codec
      GGUFs that escaped the
      pre-launch arch+name filter.
    end note
  end
end
R5 --> RUN : behavioral (R5 vector)

== Tree (slice 4c) ==
RUN -> TREE : characterizeTree({\n  ask, embed:undefined, seams.runSandbox\n})
note right of TREE
  Embedder NOT touched here —
  test model is the only resident
  process. Projection deferred.
end note
loop per OPENED branch (R5 ≥ θ_open)
  TREE -> STAIR : characterizeBranch(branch)
  loop per leaf, climb level 1→N until first fail
    STAIR -> CHAT : item.prompt
    CHAT --> STAIR : response
    alt check is registered scorer
      STAIR -> STAIR : runCheck(response)
    else check is sandbox request (code-tests)
      STAIR -> SBX : runSandbox({code, tests})
      alt opt-in OFF or boundary fails
        SBX --> STAIR : throw SandboxUnavailable
        STAIR -> STAIR : mark UNMEASURED\n(branch prior D12)
      else
        SBX -> SBX : spawn python (POSIX rlimits / Win Job)
        SBX --> STAIR : {pass:true|false}
      end
    end
  end
end
TREE --> RUN : scores_per_leaf,\nbranch_scores,\npasses_per_leaf

== Free-gen phase 1 — TEXT only (no embedder) ==
alt freegen=true
  TREE -> FG : generateFreeGenText(ask)
  FG -> CHAT : FREEGEN_PROMPT
  CHAT --> FG : ~600-800 words
  FG --> TREE : { text, words }
end

TREE --> RUN : signature with\nfreegen_text (no projection yet)
RUN -> SIG : writeSignature(skipWrite?)
RUN -> LAUNCH : stop chat server
RUN --> UI : status:'tests done'

== Free-gen phase 2 — PROJECTION (per model, deferred) ==
note over RUN
  characterizeAll's per-model loop:
  test session ended ⇒ chat server stopped ⇒
  embedder CLI is the only thing in RAM.
end note
alt skipProjection=false AND embedder available
  RUN -> EMB_CLI : embed([freegen_text, ...17 anchors])
  EMB_CLI -> EMB_CLI : spawn llama-embedding.exe\n--embd-output-format json\n--log-disable
  EMB_CLI --> RUN : Float32Array[]\n(process exits, RAM freed)
  RUN -> FG : projectFreeGenText(text, embed, anchors)
  FG --> RUN : topic_coverage_*\n(per leaf + per branch)
  RUN -> SIG : patch signature\n(topic_coverage_per_leaf,\n topic_coverage_per_branch)
else
  note right of RUN
    skipProjection=true OR no embedder
    configured ⇒ text saved, projection
    deferred (can run later on-demand).
  end note
end

RUN --> UI : status:'done' + signature
UI -> UI : refresh radar (R5 + tree + projection)

@enduml
