@startuml sandbox-execution
!include ../_includes/style.iuml

title STR_SBXEXEC_TITLE

participant "staircase.\nevaluateItem" as STAIR
participant "STR_SBXEXEC_RUN" as RUN
participant "getSandbox({enabled})" as DISP
participant "PosixSandbox\n/ WindowsSandbox\n/ UnsafeSandbox" as PROV
participant "spawn (child_process)" as SPAWN
participant "kernel\n(rlimits / Job Object)" as KERNEL
participant "STR_SBXEXEC_PY" as PY

STAIR -> RUN : STR_SBXEXEC_MSG_ITEM_SBX
RUN -> DISP : STR_SBXEXEC_MSG_ENABLED_Q
DISP --> RUN : STR_SBXEXEC_MSG_PROV_INSTANCE

alt STR_SBXEXEC_ALT_UNSAFE
  RUN -> PROV : runPythonTests(code, tests)
  PROV --> RUN : throw SandboxUnavailable
  RUN --> STAIR : STR_SBXEXEC_MSG_ITEM_UNMEAS
else STR_SBXEXEC_ELSE_POSIX
  RUN -> PROV : runPythonTests(code, tests)
  PROV -> PROV : STR_SBXEXEC_MSG_FINDPY
  alt STR_SBXEXEC_ALT_PROBE_FAILS
    PROV --> RUN : throw SandboxUnavailable
    RUN --> STAIR : UNMEASURED
  else STR_SBXEXEC_ELSE_PROBE_OK
    PROV -> PROV : STR_SBXEXEC_MSG_MKDTEMP
    PROV -> SPAWN : STR_SBXEXEC_MSG_PYTHON_ISB
    SPAWN -> PY : exec
    PY -> KERNEL : setrlimit NPROC=cur,\n  AS=512M, CPU=10s, FSIZE=0
    KERNEL --> PY : STR_SBXEXEC_MSG_ARM_LIMITS
    PY -> PY : STR_SBXEXEC_MSG_RUN_CODE
    alt asserts pass, exit 0
      PY --> SPAWN : exit 0
      SPAWN --> PROV : close(0)
      PROV --> RUN : {pass: true}
    else STR_SBXEXEC_ELSE_ASSERT_FAIL
      PY --> SPAWN : exit 1
      PROV --> RUN : {pass: false, reason: exit-nonzero}
    else STR_SBXEXEC_ELSE_TIMEOUT
      PROV -> PROV : kill -pgid SIGKILL
      PROV --> RUN : {pass: false, reason: timeout}
    else STR_SBXEXEC_ELSE_OVERFLOW
      PROV -> PROV : kill -pgid SIGKILL
      PROV --> RUN : {pass: false, reason: output-overflow}
    end
    PROV -> PROV : rmtree workdir (finally)
  end
else STR_SBXEXEC_ELSE_WIN
  RUN -> PROV : runPythonTests(code, tests)
  PROV -> SPAWN : powershell.exe -File win-job.ps1
  SPAWN -> KERNEL : CreateJobObject +\n  SetInformationJobObject\n  (ActiveProcess=1,\n   MemoryLimit=512MiB,\n   KILL_ON_JOB_CLOSE)
  KERNEL --> SPAWN : STR_SBXEXEC_MSG_JOB_HANDLE
  SPAWN -> PY : Process.Start(python.exe)
  SPAWN -> KERNEL : AssignProcessToJobObject
  PY -> PY : STR_SBXEXEC_MSG_RUN_SCRIPT
  alt STR_SBXEXEC_ALT_WAIT_OK
    PY --> SPAWN : STR_SBXEXEC_MSG_EXIT_CODE
    SPAWN --> PROV : STR_SBXEXEC_MSG_EXIT_CODE_MARKER
  else timeout
    SPAWN -> KERNEL : TerminateJobObject (1)
    SPAWN --> PROV : exit 124
  end
  PROV --> RUN : {pass, reason}
end

@enduml
