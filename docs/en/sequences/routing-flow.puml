@startuml routing-flow
!include ../_includes/style.iuml

title STR_RFLOW_TITLE

actor "STR_RFLOW_CLI_ACTOR" as CLI
participant "STR_RFLOW_MCP" as MCP
participant "STR_RFLOW_TOOL" as TOOL
participant "routingConfig" as CFG
participant "embedderLifecycle" as ELC
participant "llama-server\n--embedding" as EMB
participant "embedDetect\n+ reliability" as REL
participant "routeByVectors" as VEC
participant "classifyQuery\n(R5)" as R5
participant "routeDecision\n(rank + score)" as RANK
participant "STR_RFLOW_SIG" as SIG

CLI -> MCP : models.route\n{query, directory, limit, weights}
MCP -> TOOL : STR_RFLOW_MSG_DISPATCH
TOOL -> CFG : effectiveRoutingParams(cfg)
CFG --> TOOL : {thetaQ, embedder, …}
TOOL -> SIG : STR_RFLOW_MSG_LIST_CANDS
SIG --> TOOL : RouteCandidate[]
TOOL -> TOOL : probeFreeMemory()

alt STR_RFLOW_ALT_EMB_CONFIG
  TOOL -> ELC : STR_RFLOW_MSG_ENSURE_READY
  ELC -> EMB : STR_RFLOW_MSG_SPAWN_IF_MANAGED
  ELC --> TOOL : baseUrl
  TOOL -> REL : STR_RFLOW_MSG_MEASURE_REL
  REL --> TOOL : STR_RFLOW_MSG_COSINES
  alt STR_RFLOW_ALT_ALL_LANGS_OK
    TOOL -> VEC : routeByVectors({\n  embedder, candidates,\n  query, params})
    VEC -> EMB : embed(query)
    EMB --> VEC : STR_RFLOW_MSG_QUERY_VEC
    VEC -> VEC : STR_RFLOW_MSG_PROJ_BLEND
    VEC --> TOOL : routedBy:'vector',\nlevel, ranked
  else STR_RFLOW_ELSE_LANG_BELOW
    TOOL -> R5 : STR_RFLOW_MSG_CLASSIFY_FALLBACK
    R5 --> TOOL : axisWeights
    TOOL -> RANK : STR_RFLOW_MSG_SCORE_R5
    RANK --> TOOL : routedBy:'r5',\nranked
  end
else STR_RFLOW_ELSE_NO_EMB
  TOOL -> R5 : STR_RFLOW_MSG_CLASSIFY_DEFAULT
  R5 --> TOOL : axisWeights
  TOOL -> RANK : score
  RANK --> TOOL : routedBy:'r5'
end

TOOL --> MCP : {best, ranked, resources,\nrouting, gateReason}
MCP --> CLI : STR_RFLOW_MSG_JSON_RESP

note over CLI, TOOL
  STR_RFLOW_NOTE_ADVICE_L1
  STR_RFLOW_NOTE_ADVICE_L2
  STR_RFLOW_NOTE_ADVICE_L3
end note

note right of ELC
  STR_RFLOW_NOTE_ELC_L1
  STR_RFLOW_NOTE_ELC_L2
  STR_RFLOW_NOTE_ELC_L3
  STR_RFLOW_NOTE_ELC_L4

  STR_RFLOW_NOTE_ELC_L5
  STR_RFLOW_NOTE_ELC_L6
  STR_RFLOW_NOTE_ELC_L7
  STR_RFLOW_NOTE_ELC_L8
  STR_RFLOW_NOTE_ELC_L9
end note

@enduml
