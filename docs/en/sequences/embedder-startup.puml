@startuml embedder-startup
!include ../_includes/style.iuml

title STR_ESEQ_TITLE

== STR_ESEQ_GRP_ROUTE_A ==

participant "STR_ESEQ_ROUTE" as ROUTE
participant "embedderLifecycle" as LC
participant "STR_ESEQ_INFLIGHT" as INFLIGHT
participant "listRunning()" as LIST
participant "launchModelByPath" as LAUNCH
participant "llama-server\n--embedding (8081)" as EMB_SRV

ROUTE -> LC : ensureEmbedderReady(filePath, {model?})

alt STR_ESEQ_ALT_OTHER_LAUNCHING
  LC -> INFLIGHT : STR_ESEQ_MSG_AWAIT_PROMISE
  INFLIGHT --> LC : STR_ESEQ_MSG_REUSED
  LC --> ROUTE : {baseUrl, pid, source:'reused'}
else STR_ESEQ_ELSE_FIRST
  LC -> LIST : STR_ESEQ_MSG_LOOK_LAUNCHEDBY
  alt STR_ESEQ_ALT_ALREADY_RUNNING
    LIST --> LC : {pid, url}
    LC --> ROUTE : {baseUrl: url, source:'reused'}
  else STR_ESEQ_ELSE_NEEDS_SPAWN
    LC -> LC : STR_ESEQ_MSG_SET_INFLIGHT
    LC -> LAUNCH : launchModelByPath(\n  launchedBy:'embedder',\n  port: 8081,\n  customArgs:'--embedding'\n)
    LAUNCH -> EMB_SRV : spawn (port 8081)
    LAUNCH --> LC : {pid, url, ok}
    alt STR_ESEQ_ALT_LAUNCH_FAILED
      LC --> ROUTE : STR_ESEQ_MSG_NULL_FALLBACK
    else STR_ESEQ_ELSE_LAUNCHED
      loop STR_ESEQ_LOOP_UNTIL_READY
        LC -> EMB_SRV : STR_ESEQ_MSG_FETCH_MODELS
        alt STR_ESEQ_ALT_RESPONSE_OK
          EMB_SRV --> LC : 200
          LC --> ROUTE : {baseUrl, pid, source:'launched'}
        else STR_ESEQ_ELSE_PROC_EXITED
          LC -> LAUNCH : stopProcess(pid)
          LC --> ROUTE : null
        else STR_ESEQ_ELSE_STILL_WARMING
          LC -> LC : STR_ESEQ_MSG_SLEEP_1S
        end
      end
    end
    LC -> LC : clear INFLIGHT
  end
end

note right of LC
  STR_ESEQ_NOTE_LC_L1
  STR_ESEQ_NOTE_LC_L2
  STR_ESEQ_NOTE_LC_L3
  STR_ESEQ_NOTE_LC_L4
end note

== STR_ESEQ_GRP_ROUTE_B ==

participant "STR_ESEQ_CHAR_ALL" as CHAR_ALL
participant "embedderCli.ts" as EMB_CLI
participant "STR_ESEQ_TMP" as TMP
participant "llama-embedding.exe\n(spawn → exit)" as EMB_CLI_PROC

CHAR_ALL -> EMB_CLI : STR_ESEQ_MSG_RESOLVE_FN
note right of EMB_CLI
  STR_ESEQ_NOTE_RESOLVE_L1
  STR_ESEQ_NOTE_RESOLVE_L2
  STR_ESEQ_NOTE_RESOLVE_L3
  STR_ESEQ_NOTE_RESOLVE_L4
  STR_ESEQ_NOTE_RESOLVE_L5
end note

loop STR_ESEQ_LOOP_PER_MODEL
  CHAR_ALL -> EMB_CLI : STR_ESEQ_MSG_EMBED_CALL
  EMB_CLI -> TMP : STR_ESEQ_MSG_WRITE_TEXTS
  EMB_CLI -> EMB_CLI_PROC : STR_ESEQ_MSG_SPAWN_EMBED
  EMB_CLI_PROC --> EMB_CLI : STR_ESEQ_MSG_JSON_EXIT
  EMB_CLI -> TMP : unlink (best-effort, finally)
  EMB_CLI --> CHAR_ALL : STR_ESEQ_MSG_FLOAT32_SORTED
end

note right of EMB_CLI_PROC
  STR_ESEQ_NOTE_CLI_PROC_L1
  STR_ESEQ_NOTE_CLI_PROC_L2
  STR_ESEQ_NOTE_CLI_PROC_L3
  STR_ESEQ_NOTE_CLI_PROC_L4
  STR_ESEQ_NOTE_CLI_PROC_L5
end note

@enduml
