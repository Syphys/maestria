@startuml mcp-call
!include ../_includes/style.iuml

title STR_MCALL_TITLE

actor "STR_MCALL_USR" as USR
participant "STR_MCALL_CC" as CC
participant "STR_MCALL_MCP" as MCP
participant "STR_MCALL_AUTH" as AUTH
participant "STR_MCALL_REG" as REG
participant "models.ts\n(tools/)" as TOOL
participant "STR_MCALL_LAUNCH" as LAUNCH
participant "llama-server\n(chat)" as CHAT
participant "logger.ts\n(~/.tagspaces/mcp.log)" as LOG
participant "STR_MCALL_PANEL" as PANEL

== STR_MCALL_GRP_SESSION_OPEN ==
USR -> CC : "STR_MCALL_MSG_RUN_MODEL"
CC -> MCP : GET /sse\nAuthorization: Bearer <user|admin>
MCP -> AUTH : STR_MCALL_MSG_VERIFY_BEARER_FRESH
AUTH --> MCP : STR_MCALL_MSG_OK_FLAG
MCP -> MCP : STR_MCALL_MSG_SSE_REG
MCP --> CC : STR_MCALL_MSG_SSE_OPEN

== STR_MCALL_GRP_NORMAL_CALL ==
CC -> MCP : POST /messages?sessionId=…\nAuthorization: Bearer <user|admin>\ntools/call models.run {path, params?}
MCP -> AUTH : STR_MCALL_MSG_VERIFY_BEARER
AUTH --> MCP : OK + isAdmin
MCP -> MCP : STR_MCALL_MSG_CALLERLABEL
MCP -> REG : dispatch CallTool(name, args, ctx)
REG -> REG : STR_MCALL_MSG_REQ_ADMIN_GATE
REG -> TOOL : handler(args, ctx)
TOOL -> TOOL : STR_MCALL_MSG_COERCE
TOOL -> TOOL : STR_MCALL_MSG_ADMIN_GATE
TOOL -> LAUNCH : launchModelByPath(canonical, {\n  launchedBy: ctx.callerLabel,\n  port, paramsOverride: merge(...),\n  elevated: false\n})
LAUNCH -> CHAT : STR_MCALL_MSG_SPAWN
CHAT --> LAUNCH : {pid, url, params}
LAUNCH --> TOOL : STR_MCALL_MSG_ACTIVE_ENTRY
TOOL --> REG : {pid, url, runnerLabel,\n  params, warnings,\n  elevated:false}
REG --> MCP : content: [{type:'text',\n  text: JSON.stringify(result)}]
MCP -> LOG : appendCallLog({caller,\n  tool, args, durationMs, ok:true})
MCP --> CC : STR_MCALL_MSG_JSONRPC
CC --> USR : "STR_MCALL_MSG_STARTED"

== STR_MCALL_GRP_ELEVATED_CALL ==
note over CC, MCP
  STR_MCALL_NOTE_ELEV_L1
  STR_MCALL_NOTE_ELEV_L2
  STR_MCALL_NOTE_ELEV_L3
  STR_MCALL_NOTE_ELEV_L4
  STR_MCALL_NOTE_ELEV_L5
end note
CC -> MCP : POST .../messages\nBearer <admin>\ntools/call models.run {path, admin:true}
MCP -> AUTH : STR_MCALL_MSG_VERIFY_ADMIN
AUTH --> MCP : OK, isAdmin=true
MCP -> REG : dispatch (ctx.isAdmin=true)
REG -> TOOL : handler(args, ctx)
TOOL -> TOOL : args.admin && ctx.isAdmin ✓
TOOL -> LAUNCH : launchModelByPath(..., elevated:true)
alt Windows
  LAUNCH -> LAUNCH : STR_MCALL_MSG_WIN_UAC
else POSIX
  LAUNCH -> LAUNCH : STR_MCALL_MSG_PKEXEC
end
LAUNCH -> CHAT : STR_MCALL_MSG_ELEV_SPAWN
CHAT --> LAUNCH : STR_MCALL_MSG_PID_ONLY
LAUNCH --> TOOL : STR_MCALL_MSG_ELEV_ACTIVE
TOOL --> REG : STR_MCALL_MSG_ELEV_WARN
REG --> MCP : content
MCP -> LOG : appendCallLog(..., ok:true)
MCP --> CC : {pid, url, elevated:true}

== STR_MCALL_GRP_ADMIN_GATED ==
note over CC, REG
  STR_MCALL_NOTE_FORB_L1
  STR_MCALL_NOTE_FORB_L2
  STR_MCALL_NOTE_FORB_L3
end note
CC -> MCP : tools/call meta.clear_folder {…}
MCP -> AUTH : STR_MCALL_MSG_VERIFY_USER
AUTH --> MCP : OK, isAdmin=false
MCP -> REG : dispatch (ctx.isAdmin=false)
REG -> REG : STR_MCALL_MSG_REQ_ADMIN_RETURN
REG -> LOG : appendCallLog(..., ok:false,\n  error: "forbidden: requires admin")
REG --> MCP : STR_MCALL_MSG_ISERR
MCP --> CC : STR_MCALL_MSG_MCP_ERR

== STR_MCALL_GRP_RENDERER_REFLECTS ==
PANEL -> LAUNCH : listRunning() (poll)
LAUNCH --> PANEL : STR_MCALL_MSG_ENTRIES
PANEL -> PANEL : STR_MCALL_MSG_GROUP_BY

== STR_MCALL_GRP_ELEV_EXIT ==
note over LAUNCH
  STR_MCALL_NOTE_ELEXIT_L1
  STR_MCALL_NOTE_ELEXIT_L2
  STR_MCALL_NOTE_ELEXIT_L3
  STR_MCALL_NOTE_ELEXIT_L4
  STR_MCALL_NOTE_ELEXIT_L5
  STR_MCALL_NOTE_ELEXIT_L6
  STR_MCALL_NOTE_ELEXIT_L7
  STR_MCALL_NOTE_ELEXIT_L8
  STR_MCALL_NOTE_ELEXIT_L9
end note

== STR_MCALL_GRP_STOP ==
CC -> MCP : tools/call models.stop {pid}
MCP -> AUTH : STR_MCALL_MSG_VERIFY_BEARER
MCP -> REG : dispatch
REG -> TOOL : handler
TOOL -> LAUNCH : stopProcess(pid)
alt STR_MCALL_ALT_NONELEV
  LAUNCH -> CHAT : STR_MCALL_MSG_SIGTERM
else STR_MCALL_ELSE_ELEV
  LAUNCH -> LAUNCH : STR_MCALL_MSG_TASKKILL
end
LAUNCH --> TOOL : {ok:true}
TOOL --> REG : {stopped:true}
REG --> MCP : content
MCP -> LOG : appendCallLog(..., ok:true)
MCP --> CC : {stopped:true}

@enduml
