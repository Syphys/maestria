@startuml routing
!include ../_includes/style.iuml
!include ../_includes/legend.iuml

title STR_RTDIA_TITLE

[*] --> ENTRY
state "STR_RTDIA_ENTRY" as ENTRY
state "STR_RTDIA_CFG" as CFG
state "STR_RTDIA_CANDS" as CANDS
state "STR_RTDIA_PROBE" as PROBE
state "STR_RTDIA_Q_EMBED" as Q_EMBED
state "STR_RTDIA_Q_GATE" as Q_GATE

state "STR_RTDIA_VEC" as VEC {
  state "STR_RTDIA_EMBED_Q" as EMBED_Q
  state "STR_RTDIA_PROJECT" as PROJECT
  state "Blend α·v_det + β·max(0, tc)\n(α=0.7, β=0.3)" as BLEND
}

state "STR_RTDIA_R5" as R5 {
  state "STR_RTDIA_CLASSIFY" as CLASSIFY
  state "STR_RTDIA_MAP_BRANCH" as MAP_BRANCH
}

state "STR_RTDIA_SCORE" as SCORE
state "STR_RTDIA_RANK" as RANK
state "STR_RTDIA_OUT" as OUT

ENTRY --> CFG
CFG --> CANDS
CANDS --> PROBE
PROBE --> Q_EMBED

Q_EMBED --> Q_GATE : STR_RTDIA_REL_CONFIGURED
Q_EMBED --> R5 : STR_RTDIA_REL_ABSENT
Q_GATE --> VEC : STR_RTDIA_REL_RELY_OK
Q_GATE --> R5 : STR_RTDIA_REL_BELOW_THR

VEC --> EMBED_Q
EMBED_Q --> PROJECT
PROJECT --> BLEND
BLEND --> SCORE

R5 --> CLASSIFY
CLASSIFY --> MAP_BRANCH
MAP_BRANCH --> SCORE

SCORE --> RANK
RANK --> OUT

note right of BLEND
  STR_RTDIA_NOTE_BLEND_L1
  STR_RTDIA_NOTE_BLEND_L2
  STR_RTDIA_NOTE_BLEND_L3
  STR_RTDIA_NOTE_BLEND_L4
  STR_RTDIA_NOTE_BLEND_L5
end note

note right of Q_GATE
  STR_RTDIA_NOTE_QGATE_L1
  STR_RTDIA_NOTE_QGATE_L2
  STR_RTDIA_NOTE_QGATE_L3
  STR_RTDIA_NOTE_QGATE_L4
end note

@enduml
