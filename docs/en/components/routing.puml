@startuml routing
!include ../_includes/style.iuml
!include ../_includes/legend.iuml

title Routing — `models.route` pipeline (slice 5b + 7)

[*] --> ENTRY
state "models.route MCP tool" as ENTRY
state "load routing config\n+ effectiveRoutingParams()" as CFG
state "list candidate models\n(complete signatures only — D9)" as CANDS
state "Probe free memory\n(VRAM/RAM, resident set)" as PROBE
state "Embedder configured?" as Q_EMBED
state "Reliability gate ≥ θ" as Q_GATE

state "VECTOR path (routedBy:'vector')" as VEC {
  state "EmbedClient → query vector\n(slice 7e ensureEmbedderReady)" as EMBED_Q
  state "Project onto 32 leaf anchors\n(`probe-anchors.json`)" as PROJECT
  state "Blend α·v_det + β·max(0, tc)\n(α=0.7, β=0.3)" as BLEND
}

state "R5 path (routedBy:'r5')" as R5 {
  state "classifyQuery()\ndeterministic axis weights" as CLASSIFY
  state "Map onto branch priors" as MAP_BRANCH
}

state "Score each candidate\nC_m = Σ q[i]·v_m[i]\n+ w_fit·fit + w_hot·hot" as SCORE
state "rank + select best\nfilter to eligible (D9)" as RANK
state "return {routedBy, gateReason,\n best, ranked, resources, …}" as OUT

ENTRY --> CFG
CFG --> CANDS
CANDS --> PROBE
PROBE --> Q_EMBED

Q_EMBED --> Q_GATE : configured\n(managed or external)
Q_EMBED --> R5 : absent\n(R5 fallback)
Q_GATE --> VEC : embeddingReliability\n≥ threshold
Q_GATE --> R5 : below threshold\n(gateReason explains)

VEC --> EMBED_Q
EMBED_Q --> PROJECT
PROJECT --> BLEND
BLEND --> SCORE

R5 --> CLASSIFY
CLASSIFY --> MAP_BRANCH
MAP_BRANCH --> SCORE

SCORE --> RANK
RANK --> OUT

note right of BLEND
  topic_coverage_per_leaf
  (slice 7c) is **additional
  evidence**, never replaces
  the deterministic competence.
  See DECISIONS.md DCC.
end note

note right of Q_GATE
  Failure to embed query or
  read reliability ⇒ silently
  fall back to R5. Routing
  is **never blocking**.
end note

@enduml
