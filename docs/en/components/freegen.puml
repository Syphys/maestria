@startuml freegen
!include ../_includes/style.iuml

title STR_FGDIA_TITLE

state "STR_FGDIA_TREE_DONE" as TREE_DONE
state "characterizeTree.ts\n  if (opts.freegen !== false) {…}" as GATE_FG

state "STR_FGDIA_PHASE1" as PHASE1 {
  state "STR_FGDIA_ASK" as ASK
  state "Strip <think>…</think>\n(D11)" as STRIP
  state "STR_FGDIA_TEXT_OUT" as TEXT_OUT
}

state "STR_FGDIA_MERGE_TEXT" as MERGE_TEXT

state "STR_FGDIA_PHASE2" as PHASE2 {
  state "STR_FGDIA_EMB_TEXT" as EMB_TEXT
  state "STR_FGDIA_EMB_ANCHORS" as EMB_ANCHORS
  state "STR_FGDIA_PROJECT" as PROJECT
  state "STR_FGDIA_PROJ_OUT" as PROJ_OUT
}

state "STR_FGDIA_MERGE_PROJ" as MERGE_PROJ

state "STR_FGDIA_SKIP_FG" as SKIP_FG
state "STR_FGDIA_SKIP_E" as SKIP_E

TREE_DONE --> GATE_FG
GATE_FG --> PHASE1 : STR_FGDIA_REL_FREEGEN_ON
GATE_FG --> SKIP_FG : STR_FGDIA_REL_EXPLICIT_OFF
PHASE1 --> ASK
ASK --> STRIP
STRIP --> TEXT_OUT
TEXT_OUT --> MERGE_TEXT

state "STR_FGDIA_BULK_LOOP" as BULK_LOOP
state "STR_FGDIA_PROJ_GATE" as PROJ_GATE
MERGE_TEXT --> BULK_LOOP : STR_FGDIA_REL_SIG_SAVED
BULK_LOOP --> PROJ_GATE
PROJ_GATE --> PHASE2 : STR_FGDIA_REL_EMB_AVAIL
PROJ_GATE --> [*] : STR_FGDIA_REL_SKIP_PROJ

PHASE2 --> EMB_TEXT
EMB_TEXT --> EMB_ANCHORS
EMB_ANCHORS --> PROJECT
PROJECT --> PROJ_OUT
PROJ_OUT --> MERGE_PROJ

PHASE1 --> SKIP_E : STR_FGDIA_REL_THROW_CAUGHT

note right of PHASE1
  STR_FGDIA_NOTE_PH1_L1
  STR_FGDIA_NOTE_PH1_L2
  STR_FGDIA_NOTE_PH1_L3
end note

note right of PHASE2
  STR_FGDIA_NOTE_PH2_L1
  STR_FGDIA_NOTE_PH2_L2
  STR_FGDIA_NOTE_PH2_L3
  STR_FGDIA_NOTE_PH2_L4
  STR_FGDIA_NOTE_PH2_L5
end note

note bottom of MERGE_PROJ
  STR_FGDIA_NOTE_MP_L1
  STR_FGDIA_NOTE_MP_L2
  STR_FGDIA_NOTE_MP_L3
  STR_FGDIA_NOTE_MP_L4
end note

note bottom of SKIP_E
  STR_FGDIA_NOTE_SE_L1
  STR_FGDIA_NOTE_SE_L2
  STR_FGDIA_NOTE_SE_L3
  STR_FGDIA_NOTE_SE_L4
end note

@enduml
