@startuml sandbox
!include ../_includes/style.iuml

title STR_SBXDIA_TITLE

package "src/main/modelhub/routing/sandbox/" {
  component "STR_SBXDIA_IDX" as IDX
  component "types.ts\n• SandboxProvider (ABC)\n• SandboxResult\n• SandboxOptions\n• SandboxUnavailable" as TYPES

  component "STR_SBXDIA_UNSAFE" as UNSAFE
  component "STR_SBXDIA_POSIX" as POSIX
  component "STR_SBXDIA_WIN" as WIN
  component "STR_SBXDIA_PS1" as PS1
}

component "STR_SBXDIA_RUNNER" as RUNNER
component "STR_SBXDIA_STAIR" as STAIR

RUNNER --> IDX : getSandbox({enabled})
IDX --> UNSAFE : STR_SBXDIA_REL_UNSAFE
IDX --> POSIX : enabled:true\n+ linux/darwin
IDX --> WIN : enabled:true\n+ win32

WIN --> PS1 : spawn powershell.exe\n-File win-job.ps1
POSIX ..> "STR_SBXDIA_PY_LABEL" : spawn\ndetached:true
PS1 ..> "STR_SBXDIA_PYEXE_LABEL" : Process.Start +\nAssignProcessToJobObject

UNSAFE -.-> STAIR : STR_SBXDIA_REL_UNSAFE_STAIR
POSIX -.-> STAIR : STR_SBXDIA_REL_POSIX_STAIR
WIN -.-> STAIR : STR_SBXDIA_REL_WIN_STAIR

note bottom of IDX
  STR_SBXDIA_NOTE_IDX_L1
  STR_SBXDIA_NOTE_IDX_L2
  STR_SBXDIA_NOTE_IDX_L3
  STR_SBXDIA_NOTE_IDX_L4
  STR_SBXDIA_NOTE_IDX_L5
  STR_SBXDIA_NOTE_IDX_L6
end note

note right of POSIX
  STR_SBXDIA_NOTE_POSIX_L1
  STR_SBXDIA_NOTE_POSIX_L2
  STR_SBXDIA_NOTE_POSIX_L3
  STR_SBXDIA_NOTE_POSIX_L4
end note

@enduml
