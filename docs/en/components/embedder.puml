@startuml embedder
!include ../_includes/style.iuml
!include ../_includes/actors.iuml

title STR_EMBDIA_TITLE

package "src/main/modelhub/" {
  component "STR_EMBDIA_EMBED_LC" as EMBED_LC
  component "STR_EMBDIA_EMBED_CLI" as EMBED_CLI
  component "launchModelByPath\n(via launch.ts)\nlaunchedBy: 'embedder'\ncustomArgs: '--embedding'" as LAUNCH
  component "EmbedClient\n(routing/embed.ts)\nHTTP POST /v1/embeddings" as EMBED_CLIENT
  component "routingConfig.ts\n.routingEmbedderPath /\n.routingEmbedderBaseUrl" as RC
}

component "STR_EMBDIA_CHAR_ALL" as CHAR_ALL
component "STR_EMBDIA_ROUTE" as ROUTE

CHAR_ALL --> EMBED_CLI : STR_EMBDIA_REL_CHAR_EMB
ROUTE --> RC : effectiveRoutingParams.embedder

RC --> EMBED_LC : kind:'managed'\n+ filePath\n(server-backed)
RC ..> EMBED_CLIENT : kind:'external'\n+ baseUrl (direct)

EMBED_LC --> LAUNCH : STR_EMBDIA_REL_SPAWN_IF
LAUNCH --> LLAMA_EMBED : llama-server\n--embedding (port 8081)
LLAMA_EMBED --> EMBED_LC : STR_EMBDIA_REL_READY_PROBE
EMBED_LC --> EMBED_CLIENT : baseUrl
EMBED_CLIENT --> LLAMA_EMBED : POST /v1/embeddings

component "STR_EMBDIA_LLAMA_CLI" as LLAMA_EMBED_CLI
EMBED_CLI ..> LLAMA_EMBED_CLI : STR_EMBDIA_REL_SPAWN_ONESHOT

note right of LLAMA_EMBED_CLI
  STR_EMBDIA_NOTE_CLI_L1
  STR_EMBDIA_NOTE_CLI_L2
  STR_EMBDIA_NOTE_CLI_L3
  STR_EMBDIA_NOTE_CLI_L4
end note

note bottom of EMBED_LC
  STR_EMBDIA_NOTE_LC_L1
  STR_EMBDIA_NOTE_LC_L2
  STR_EMBDIA_NOTE_LC_L3
  STR_EMBDIA_NOTE_LC_L4
end note

note bottom of EMBED_CLI
  STR_EMBDIA_NOTE_CLI2_L1
  STR_EMBDIA_NOTE_CLI2_L2
  STR_EMBDIA_NOTE_CLI2_L3
  STR_EMBDIA_NOTE_CLI2_L4
  STR_EMBDIA_NOTE_CLI2_L5
  STR_EMBDIA_NOTE_CLI2_L6
end note

note right of LLAMA_EMBED
  STR_EMBDIA_NOTE_LLAMA_L1
  STR_EMBDIA_NOTE_LLAMA_L2
  STR_EMBDIA_NOTE_LLAMA_L3
end note

@enduml
