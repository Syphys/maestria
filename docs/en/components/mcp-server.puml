@startuml mcp-server
!include ../_includes/style.iuml
!include ../_includes/actors.iuml

title STR_MCPDIA_TITLE

package "src/main/modelhub/mcp/" as MCP_PKG {
  component "STR_MCPDIA_INDEX" as INDEX
  component "STR_MCPDIA_SERVER" as SERVER
  component "STR_MCPDIA_REG" as REG
  component "STR_MCPDIA_TOKEN" as TOKEN
  component "STR_MCPDIA_LOGGER" as LOGGER

  package "STR_MCPDIA_TOOLS_PKG_LABEL" as TOOLS {
    component "STR_MCPDIA_T_MODELS" as T_MODELS
    component "STR_MCPDIA_T_ROUTE" as T_ROUTE
    component "characterize.ts (6)\n• start / status\n• all_start (long)\n• all_cancel\n• load_signature\n• get_questions_dir" as T_CHAR
    component "logs.ts (4)\n• models.get_server_log\n• models.get_error_log\n• models.list_archives\n• runners.get_log" as T_LOGS
    component "STR_MCPDIA_T_META" as T_META
    component "discovery.ts (2)\n• sum_shard_bytes\n• list_hosting_folders" as T_DISC
    component "STR_MCPDIA_T_RUNN" as T_RUNN
    component "configs.ts (5) ⚠\n• hardware.detect_raw\n• hardware.get_override\n• hardware.set_override ⚠\n• routing.get_config\n• routing.set_config ⚠" as T_CFG
    component "tags.ts (2)\n• tags.add\n• tags.remove" as T_TAGS
    component "description.ts (2)\n• description.get\n• description.set" as T_DESC
    component "hardware.ts (2)\n• hardware.detect\n• hardware.autotune" as T_HW
  }
}

component "launch.ts\n+ launchProcessElevated\n(UAC / pkexec)" as LAUNCH
component "routeDecision.ts\n+ routeByVectors.ts\n+ embedderLifecycle" as ROUTE_CORE
component "characterizeRunner.ts\n+ characterizeAll.ts" as CHAR_CORE
component "modelLogStore.ts\n+ runners/launch.getEntryLog" as LOGS_CORE
component "enrichFolder + clearFolder\n+ sidecar.patchModelMeta" as META_CORE
component "runners/registry +\nfitProbe + openChat" as RUNN_CORE
component "hardwareOverride +\nroutingConfig" as CFG_CORE
component "STR_MCPDIA_UI_SETTINGS_R" as UI_SETTINGS_R

MCP_CLIENT --> SERVER : GET /sse\nPOST /messages?sessionId=…\nAuthorization: Bearer <user|admin>
SERVER --> TOKEN : STR_MCPDIA_REL_VERIFY_BEARER
SERVER --> REG : STR_MCPDIA_REL_DISPATCH
SERVER --> LOGGER : STR_MCPDIA_REL_APPEND_LOG

REG --> T_MODELS
REG --> T_ROUTE
REG --> T_CHAR
REG --> T_LOGS
REG --> T_META : STR_MCPDIA_REL_ADMIN_GATED
REG --> T_DISC
REG --> T_RUNN : STR_MCPDIA_REL_ADMIN_GATED
REG --> T_CFG  : STR_MCPDIA_REL_ADMIN_GATED
REG --> T_TAGS
REG --> T_DESC
REG --> T_HW

INDEX ..> T_MODELS : import (register)
INDEX ..> T_ROUTE  : import (register)
INDEX ..> T_CHAR   : import (register)
INDEX ..> T_LOGS   : import (register)
INDEX ..> T_META   : import (register)
INDEX ..> T_DISC   : import (register)
INDEX ..> T_RUNN   : import (register)
INDEX ..> T_CFG    : import (register)
INDEX ..> T_TAGS   : import (register)
INDEX ..> T_DESC   : import (register)
INDEX ..> T_HW     : import (register)

T_MODELS --> LAUNCH : STR_MCPDIA_REL_T_MODELS_LAUNCH
T_MODELS --> SIDECARS : STR_MCPDIA_REL_T_MODELS_SIDE
T_ROUTE --> ROUTE_CORE : STR_MCPDIA_REL_T_ROUTE
T_CHAR --> CHAR_CORE : runCharacterization,\ncharacterizeAll,\nloadSignature
T_LOGS --> LOGS_CORE : readServerLog / readErrorLog /\nlistServerLogArchives /\ngetEntryLog
T_META --> META_CORE : enrichLocal /\nenrichFolder /\nclearFolder /\npatchModelMeta
T_DISC --> SIDECARS : sumShardBytes /\nlistModelHostingFolders
T_RUNN --> RUNN_CORE : listRunners / saveRunner /\nremoveRunner / reprobe /\nfitProbe / openChatFor /\nbuildCommand
T_CFG --> CFG_CORE : getOverride / setOverride /\ngetRoutingConfig / setRoutingConfig
T_TAGS --> SIDECARS : patchSidecar({tags})
T_DESC --> SIDECARS : patchSidecar({description})
T_HW ..> "STR_MCPDIA_HW_LABEL" : STR_MCPDIA_REL_T_HW

UI_SETTINGS_R --> INDEX : STR_MCPDIA_REL_UI_SETTINGS

note bottom of REG
  STR_MCPDIA_NOTE_REG_L1
  STR_MCPDIA_NOTE_REG_L2
  STR_MCPDIA_NOTE_REG_L3
  STR_MCPDIA_NOTE_REG_L4
  STR_MCPDIA_NOTE_REG_L5
  STR_MCPDIA_NOTE_REG_L6
  STR_MCPDIA_NOTE_REG_L7
  STR_MCPDIA_NOTE_REG_L8
  STR_MCPDIA_NOTE_REG_L9
  STR_MCPDIA_NOTE_REG_L10
  STR_MCPDIA_NOTE_REG_L11
  STR_MCPDIA_NOTE_REG_L12
end note

note bottom of SERVER
  STR_MCPDIA_NOTE_SRV_L1
  STR_MCPDIA_NOTE_SRV_L2
  STR_MCPDIA_NOTE_SRV_L3
  STR_MCPDIA_NOTE_SRV_L4
  STR_MCPDIA_NOTE_SRV_L5
  STR_MCPDIA_NOTE_SRV_L6
  STR_MCPDIA_NOTE_SRV_L7
  STR_MCPDIA_NOTE_SRV_L8
  STR_MCPDIA_NOTE_SRV_L9
  STR_MCPDIA_NOTE_SRV_L10
  STR_MCPDIA_NOTE_SRV_L11
  STR_MCPDIA_NOTE_SRV_L12
end note

@enduml
