@startuml characterization
!include ../_includes/style.iuml
!include ../_includes/legend.iuml

title STR_CHARDIA_TITLE

package "src/main/modelhub/" {
  component "STR_CHARDIA_LOG_STORE" as LOG_STORE
}

package "src/main/modelhub/routing/" {
  component "STR_CHARDIA_ALL" as ALL

  component "STR_CHARDIA_RUNNER" as RUNNER

  component "STR_CHARDIA_R5_RUN" as R5_RUN

  component "STR_CHARDIA_TREE" as TREE

  component "STR_CHARDIA_STAIR" as STAIR

  package "scorers/" as SCORERS_PKG {
    component "STR_CHARDIA_SCORER_CORE" as SCORER_CORE
    component "STR_CHARDIA_DET_SCORERS" as DET_SCORERS
    component "STR_CHARDIA_AXIS_SCORERS" as AXIS_SCORERS
    component "STR_CHARDIA_INFO_SCORER" as INFO_SCORER
    component "STR_CHARDIA_PEND_SCORERS" as PEND_SCORERS
  }

  component "STR_CHARDIA_FREEGEN" as FREEGEN
  component "embedderCli.ts\n(2026-05-23)\n• embedViaLlamaCli\n  (spawn → JSON → exit)\n• resolveEmbedderCliFn" as EMB_CLI
  component "sandbox/\n(slice 2d)\nindex → posix |\n      windows |\n      unsafe" as SANDBOX
  component "STR_CHARDIA_STORE" as STORE
}

ALL --> RUNNER : STR_CHARDIA_REL_ALL_RUNNER
ALL --> EMB_CLI : STR_CHARDIA_REL_ALL_EMB
ALL --> FREEGEN : STR_CHARDIA_REL_ALL_FG
RUNNER --> R5_RUN : STR_CHARDIA_REL_R5
RUNNER --> TREE : STR_CHARDIA_REL_TREE
TREE --> FREEGEN : STR_CHARDIA_REL_TREE_FG
TREE --> STAIR : STR_CHARDIA_REL_TREE_STAIR
STAIR --> SCORER_CORE : runCheck(item.check)
SCORER_CORE --> DET_SCORERS
SCORER_CORE --> AXIS_SCORERS
SCORER_CORE --> INFO_SCORER
SCORER_CORE --> PEND_SCORERS
PEND_SCORERS --> SANDBOX : STR_CHARDIA_REL_PEND_SBX
RUNNER --> STORE : finalResult ↩\nsignature
TREE --> STORE : STR_CHARDIA_REL_TREE_STORE
FREEGEN ..> STORE : STR_CHARDIA_REL_FG_STORE

ALL ..> LOG_STORE : STR_CHARDIA_REL_ALL_LOG
RUNNER ..> LOG_STORE : STR_CHARDIA_REL_RUNNER_LOG

note bottom of RUNNER
  STR_CHARDIA_NOTE_RUNNER_L1
  STR_CHARDIA_NOTE_RUNNER_L2
  STR_CHARDIA_NOTE_RUNNER_L3
  STR_CHARDIA_NOTE_RUNNER_L4
  STR_CHARDIA_NOTE_RUNNER_L5
  STR_CHARDIA_NOTE_RUNNER_L6
  STR_CHARDIA_NOTE_RUNNER_L7
end note

note right of STAIR
  STR_CHARDIA_NOTE_STAIR_L1
  leaf_score = (1+passes)/(2+asked)
  STR_CHARDIA_NOTE_STAIR_L3
  STR_CHARDIA_NOTE_STAIR_L4
end note

note right of ALL
  STR_CHARDIA_NOTE_ALL_L1
  STR_CHARDIA_NOTE_ALL_L2
  STR_CHARDIA_NOTE_ALL_L3
     STR_CHARDIA_NOTE_ALL_L4
     STR_CHARDIA_NOTE_ALL_L5
     STR_CHARDIA_NOTE_ALL_L6
       STR_CHARDIA_NOTE_ALL_L7
  STR_CHARDIA_NOTE_ALL_L8
  STR_CHARDIA_NOTE_ALL_L9
end note

@enduml
