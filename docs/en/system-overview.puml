@startuml system-overview
!include _includes/style.iuml
!include _includes/actors.iuml

title STR_SYSOV_TITLE

package "STR_SYSOV_MAESTRIA_PKG" as MAESTRIA {
  package "Renderer (React)" {
    component "STR_SYSOV_UI_PANEL" as UI_PANEL
    component "STR_SYSOV_UI_RADAR" as UI_RADAR
    component "STR_SYSOV_UI_SETTINGS" as UI_SETTINGS
  }
  package "STR_SYSOV_MAIN_PKG" {
    component "STR_SYSOV_MCP_SERVER" as MCP_SERVER
    component "STR_SYSOV_REGISTRY" as REGISTRY
    component "STR_SYSOV_ROUTING" as ROUTING
    component "STR_SYSOV_CHARACT" as CHARACT
    component "STR_SYSOV_SANDBOX" as SANDBOX
    component "STR_SYSOV_EMBED_LC" as EMBED_LC
    component "STR_SYSOV_RUNNERS" as RUNNERS
  }
}

USER --> UI_PANEL : STR_SYSOV_REL_OPEN_GGUF
USER --> UI_SETTINGS : STR_SYSOV_REL_USER_SETTINGS
UI_PANEL --> CHARACT : STR_SYSOV_REL_CHARACTERIZE
UI_PANEL --> RUNNERS : Run (chat)
UI_RADAR --> CHARACT : STR_SYSOV_REL_RECHAR

MCP_CLIENT --> MCP_SERVER : HTTP+SSE\n(Bearer token)
MCP_SERVER --> REGISTRY
REGISTRY --> ROUTING : models.route
REGISTRY --> CHARACT : STR_SYSOV_REL_VIA_TOOLS
REGISTRY --> RUNNERS : models.run / .stop

CHARACT --> RUNNERS : STR_SYSOV_REL_ENSURE_CHAT
CHARACT --> EMBED_LC : STR_SYSOV_REL_OPT_PROBE
CHARACT --> SANDBOX : STR_SYSOV_REL_CODE_TESTS
ROUTING --> EMBED_LC : STR_SYSOV_REL_PROJ_QUERY

RUNNERS --> LLAMA_CHAT : spawn
EMBED_LC --> LLAMA_EMBED : spawn\n--embedding
SANDBOX --> PYTHON_SANDBOX : STR_SYSOV_REL_ISOLATED_SPAWN

CHARACT --> SIDECARS : STR_SYSOV_REL_WRITE_SIG
ROUTING --> SIDECARS : STR_SYSOV_REL_READ_SIG

note bottom of MAESTRIA
  STR_SYSOV_NOTE_L1
  STR_SYSOV_NOTE_L2
  STR_SYSOV_NOTE_L3
  STR_SYSOV_NOTE_L4
end note

@enduml
