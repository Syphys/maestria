' Bonus — Salt UI mockups. Salt is PlantUML's built-in mock-up
' language. Useful when describing UX flows to contributors without
' a screenshot in git LFS. Salt needs @startsalt/@endsalt — embedding
' it inside @startuml + `salt { … }` no longer works as of
' PlantUML 1.2026.x. Each mockup is a separate top-level block so
' the renderer emits one image per panel.
'
' The i18n preamble below has to be repeated inside each @startsalt
' block because Salt opens a fresh preprocessor scope per block
' (PlantUML 1.2026.x — `!define` from outside the block isn't seen).

@startsalt mockup-inference-tab
!ifndef LANG
!define LANG en
!endif
!if (LANG == "fr")
!include ../_includes/i18n/strings_fr.iuml
!else
!include ../_includes/i18n/strings_en.iuml
!endif
{
  {/ Tags | Description | <b>Inférence</b> | Linked }
  {* STR_MOCK_INF_MODEL_LBL | qwen-coder-32b.gguf [Q4_K_M] | 18 GB | ctx 32768 }
  --
  {[ ▶ Run ▼ ] | STR_MOCK_INF_RUNNER_LBL | STR_MOCK_INF_CONFIGURE_BTN }
  --
  {+ <b>STR_MOCK_INF_RUN_PARAMS</b>           |        |       }
  {     STR_MOCK_INF_PARAM_COL | STR_MOCK_INF_ESTIM_COL | STR_MOCK_INF_USED_COL       }
  {     ngl       |     99    |     99     }
  {     ctx       |   32768   |   32768    }
  {     threads   |     8     |      8     }
  {     batch     |    512    |    512     }
  {     flashAttn |    on     |     on     }
  {     mlock     |   false   |    false   }
  {     fit       |    ✓ on   |   ✓ on     }
  --
  {[ STR_MOCK_INF_ADV_PARAMS_BTN ]                     }
  --
  {<b>Compétence</b> STR_MOCK_INF_COMP_SUFFIX                  }
  {        radar (R5 — 16 axes)                                 }
  {      ▸ STR_MOCK_INF_ARBRE                    }
  {      ▸ Parler libre (freegen_text + projection)             }
  {                                                              }
  {<i>STR_MOCK_INF_SUITE</i>          }
  {[ ⚗ Re-caractériser ] | [ ❓ Questions sources ]            }
}
@endsalt

