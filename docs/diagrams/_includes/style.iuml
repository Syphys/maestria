' ───────────────────────────────────────────────────────────────
' Shared style — every .puml in this folder !includes this file.
' Keeps colour + skin consistent. Maestria palette mirrors
' `branding/colors.md` (ink / graphite / cream / copper).
' ───────────────────────────────────────────────────────────────

skinparam backgroundColor #F4EEE3
skinparam defaultFontName "Inter, Helvetica, sans-serif"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 8

skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #0E1014
  FontColor #0E1014
  ArrowColor #1A1D24
}

skinparam package {
  BackgroundColor #F4EEE3
  BorderColor #7A7569
  FontColor #0E1014
}

skinparam database {
  BackgroundColor #E6DFD2
  BorderColor #0E1014
}

skinparam queue {
  BackgroundColor #E6DFD2
  BorderColor #0E1014
}

skinparam note {
  BackgroundColor #FFFDF6
  BorderColor #C68A3A
  FontColor #0E1014
}

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #0E1014
  ArrowColor #1A1D24
}

skinparam sequence {
  ArrowColor #1A1D24
  ActorBorderColor #0E1014
  LifeLineBorderColor #7A7569
  ParticipantBorderColor #0E1014
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #0E1014
  GroupBorderColor #C68A3A
  GroupFontColor #C68A3A
}

skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #0E1014
}

skinparam node {
  BackgroundColor #1A1D24
  BorderColor #0E1014
  FontColor #F4EEE3
}
