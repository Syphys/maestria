@startuml system-overview
!include _includes/style.iuml
!include _includes/actors.iuml

title Maestria — AI subsystem overview

package "Maestria (Electron app)" as MAESTRIA {
  package "Renderer (React)" {
    component "ModelHubPanel\n+ Inférence tab" as UI_PANEL
    component "CompetenceSection\n(R5 radar +\ntree radar)" as UI_RADAR
    component "Settings ▸ AI\n▸ Routing" as UI_SETTINGS
  }
  package "Main process" {
    component "MCP server\n(127.0.0.1:41541,\nBearer auth)" as MCP_SERVER
    component "Tools registry\n(models.*,\ntags.*, hf.*,\nhardware.*, route)" as REGISTRY
    component "Routing\n(routeByVectors\n+ R5 fallback)" as ROUTING
    component "Characterization\nrunner + tree\n+ staircase" as CHARACT
    component "Sandbox dispatch\n(POSIX rlimits /\nWin Job Object /\nUnsafe)" as SANDBOX
    component "Embedder\nlifecycle\n(slice 7e)" as EMBED_LC
    component "Runner registry\n+ launch.ts\n(llama-server)" as RUNNERS
  }
}

USER --> UI_PANEL : opens a .gguf
USER --> UI_SETTINGS : configure embedder /\nsandbox opt-in
UI_PANEL --> CHARACT : characterize
UI_PANEL --> RUNNERS : Run (chat)
UI_RADAR --> CHARACT : re-characterize

MCP_CLIENT --> MCP_SERVER : HTTP+SSE\n(Bearer token)
MCP_SERVER --> REGISTRY
REGISTRY --> ROUTING : models.route
REGISTRY --> CHARACT : (via tools)
REGISTRY --> RUNNERS : models.run / .stop

CHARACT --> RUNNERS : ensure live\nchat URL
CHARACT --> EMBED_LC : optional probe\n(slice 7c)
CHARACT --> SANDBOX : code-tests\n(slice 2d)
ROUTING --> EMBED_LC : project query\n(slice 7e)

RUNNERS --> LLAMA_CHAT : spawn
EMBED_LC --> LLAMA_EMBED : spawn\n--embedding
SANDBOX --> PYTHON_SANDBOX : isolated\nspawn

CHARACT --> SIDECARS : write signature
ROUTING --> SIDECARS : read signature
REGISTRY --> HF : hf.fetch

note bottom of MAESTRIA
  100% local, offline, no telemetry.
  llama-server + python (sandbox)
  are child processes; nothing
  binds outside 127.0.0.1.
end note

@enduml
