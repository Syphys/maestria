@startuml states-sandbox-dispatch
!include ../_includes/style.iuml

title State machine — sandbox provider dispatch (slice 2d)

' One getSandbox({enabled}) call → exactly ONE end state. Then
' runPythonTests(code, tests) → exactly ONE outcome (pass / fail /
' SandboxUnavailable). Fail-closed: any uncertainty ⇒ UNMEASURED path.

[*] --> Dispatch

state "getSandbox({enabled})" as Dispatch {
  description : Reads `params.enableSandbox`\nand `process.platform`.
}

Dispatch --> UNSAFE_STATE : enabled:false\n(default)\nOR unknown OS
Dispatch --> POSIX_STATE : enabled:true\n+ linux/darwin
Dispatch --> WIN_STATE : enabled:true\n+ win32

state "UnsafeSandbox\n(opt-in off)" as UNSAFE_STATE {
  description : Always throws\nSandboxUnavailable\non runPythonTests().
}

state "PosixSandbox" as POSIX_STATE {
  state "find python3/python\n+ probe resource module" as POSIX_PROBE
  state "mkdtemp + write script\n(preamble + code + tests)" as POSIX_PREP
  state "spawn -I -S -B,\ndetached pgrp,\nempty env" as POSIX_RUN
  state "wait for close /\ntimeout / overflow" as POSIX_WAIT

  [*] --> POSIX_PROBE
  POSIX_PROBE --> POSIX_PREP : probe OK
  POSIX_PROBE --> POSIX_UNAVAIL : no python\nOR no resource
  POSIX_PREP --> POSIX_RUN : script written
  POSIX_PREP --> POSIX_UNAVAIL : mkdtemp fails\nOR write fails
  POSIX_RUN --> POSIX_WAIT
  POSIX_WAIT --> POSIX_PASS : exit 0
  POSIX_WAIT --> POSIX_FAIL_EXIT : exit ≠ 0
  POSIX_WAIT --> POSIX_FAIL_TO : wall clock ≥ timeoutMs\n→ kill -pgid
  POSIX_WAIT --> POSIX_FAIL_OV : stdout+stderr ≥ max\n→ kill -pgid

  state "{pass:true}" as POSIX_PASS #FFFDF6
  state "{pass:false,\nreason:exit-nonzero}" as POSIX_FAIL_EXIT
  state "{pass:false,\nreason:timeout}" as POSIX_FAIL_TO
  state "{pass:false,\nreason:output-overflow}" as POSIX_FAIL_OV
  state "throw\nSandboxUnavailable" as POSIX_UNAVAIL #E6DFD2
}

state "WindowsSandbox" as WIN_STATE {
  state "find py/python/python3" as WIN_PROBE
  state "mkdtemp + write script\nverify win-job.ps1 present" as WIN_PREP
  state "spawn powershell.exe\n-File win-job.ps1" as WIN_RUN
  state "PS1: CreateJobObject\n+ SetInformationJobObject\n+ Start python\n+ AssignProcessToJobObject" as WIN_JOB
  state "WaitForExit(innerTimeoutMs)" as WIN_WAIT

  [*] --> WIN_PROBE
  WIN_PROBE --> WIN_PREP : probe OK
  WIN_PROBE --> WIN_UNAVAIL : no python.exe\nOR PS1 missing
  WIN_PREP --> WIN_RUN
  WIN_PREP --> WIN_UNAVAIL : mkdtemp fails
  WIN_RUN --> WIN_JOB
  WIN_JOB --> WIN_WAIT : assigned\n(tiny race window)
  WIN_JOB --> WIN_UNAVAIL : CreateJobObject /\nSetInformationJobObject /\nAdd-Type failure
  WIN_WAIT --> WIN_PASS : exit 0
  WIN_WAIT --> WIN_FAIL_EXIT : exit ≠ 0,124
  WIN_WAIT --> WIN_FAIL_TO : exit 124\n(PS1's TerminateJobObject)

  state "{pass:true}" as WIN_PASS #FFFDF6
  state "{pass:false,\nreason:exit-nonzero}" as WIN_FAIL_EXIT
  state "{pass:false,\nreason:timeout}" as WIN_FAIL_TO
  state "throw\nSandboxUnavailable" as WIN_UNAVAIL #E6DFD2
}

note bottom of Dispatch
  Single source of truth — only this
  state machine knows about platform
  / opt-in. Callers (characterizeRunner)
  just see a SandboxProvider instance.
end note

note right of POSIX_UNAVAIL
  Fail-closed (Dαα §3): every
  SandboxUnavailable transition
  in the staircase ⇒ UNMEASURED
  (branch prior D12), never a
  false pass.
end note

@enduml
